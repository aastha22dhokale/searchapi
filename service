import java.util.Map;

import static com.ing.datadist.api.utils.DataDistributionConstants.*;

@Service
@Slf4j
public class OrganisationUnitService {

    private final OrganisationUnitOnePamRepository organisationUnitOnePamRepository;
    private final InvolvedPartyOnePamRepository invPartyOnePamRepository;
    private final CofaceOpsConfigReader configReader;
    private final AddressService addressService;
    private final DigitalAddrService digitalAddrService;
    private final OrgUnitAccountingDAO orgUnitAccountingDAO;
    private final InvolvedPartySearchService involvedPartySearchService;
    private final ErrorLogDAO errorLogDAO;
    private final ApiTransactionLogDAO apiTransactionLogDAO;
    private final MappingDAO mappingDAO;

    public OrganisationUnitService(OrganisationUnitOnePamRepository organisationUnitOnePamRepository,
                                   InvolvedPartyOnePamRepository invPartyOnePamRepository,
                                   CofaceOpsConfigReader configReader,
                                   AddressService addressService,
                                   DigitalAddrService digitalAddrService,
                                   OrgUnitAccountingDAO orgUnitAccountingDAO,
                                   InvolvedPartySearchService involvedPartySearchService,
                                   ErrorLogDAO errorLogDAO,
                                   ApiTransactionLogDAO apiTransactionLogDAO,
                                   MappingDAO mappingDAO) {
        this.organisationUnitOnePamRepository = organisationUnitOnePamRepository;
        this.invPartyOnePamRepository = invPartyOnePamRepository;
        this.configReader = configReader;
        this.addressService = addressService;
        this.digitalAddrService = digitalAddrService;
        this.orgUnitAccountingDAO = orgUnitAccountingDAO;
        this.involvedPartySearchService = involvedPartySearchService;
        this.errorLogDAO = errorLogDAO;
        this.apiTransactionLogDAO = apiTransactionLogDAO;
        this.mappingDAO = mappingDAO;
    }

    public void processOrganisationUnit(String dduuid, String opsNumber, OrganisationUnitDomainWrapper wrapper) {

        Map<String, String> config = getConfig(opsNumber);
        log.info("Processing Organisation Unit {}", opsNumber);

        String onePamUUID = "";

        CreateInvolvedPartyResponseV5 response = null;
        try {
            response = createOrganisationUnit(dduuid, wrapper);
            apiTransactionLogDAO.logApiSuccess(
                    dduuid,
                    wrapper.getFileId(),
                    COFACE_OPS_FLOW,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.endpoint,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.method,
                    200
            );
            orgUnitAccountingDAO.insertFullOrganisationUnit(response);

        } catch (Exception e) {
            apiTransactionLogDAO.logApiFailure(
                    dduuid,
                    wrapper.getFileId(),
                    COFACE_OPS_FLOW,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.endpoint,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.method,
                    "API_ERROR",
                    e.getMessage()
            );
            try {
                apiTransactionLogDAO.updateNotificationStatusByUuid(dduuid, wrapper.getFileId());
                log.info("Data_Distributor_Coface_OPS Updated notification status for dd_uuid:{} after organisation creation failure", dduuid);
            } catch (Exception statusEx) {
                log.error("Failed to update notification status for dd_uuid:{}, error:{}", dduuid, statusEx.getMessage());
            }
            return;

        }
        InvolvedPartiesOrganisationUnitResponse getOrganisationUnit = response.getOrganisationUnit();

        onePamUUID = getOrganisationUnit.getInvolvedPartyIdentifierValue();
        log.info("Involved Party Internal Identifiers : " + onePamUUID);
        if (onePamUUID == null || onePamUUID.isBlank() || onePamUUID.isEmpty()) {
            log.warn("No involvedPartyIdentifier found in response. Skipping OU flow.");
            return;
        }

        wrapper.setOnePamUuid(onePamUUID);
        UpdateExternalIdentifierInvolvedPartyRequest updateRequest = buildUpdateRequest(dduuid, wrapper);

        try {

            apiTransactionLogDAO.logApiSuccess(
                    dduuid,
                    wrapper.getFileId(),
                    COFACE_OPS_FLOW,
                    RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.endpoint,
                    RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.method,
                    200
            );

            log.info("Data_Distributor_Coface_OU Calling UpdateExternalIdentifier-API for dd_uuid:{}, onePamUuid:{}", dduuid, onePamUUID);

            Response responseUpdateExternalIdentifier =
                    invPartyOnePamRepository.updateExternalIdentifier(onePamUUID, updateRequest).get();

            orgUnitAccountingDAO.updateExternalIdentifier(
                    dduuid,
                    wrapper.getOrgExternalIdentifierVal(),
                    updateRequest.getEffectiveDate(),
                    wrapper.getOpsExternalIdentifierVal(),
                    wrapper.getFileId()
            );

            if (responseUpdateExternalIdentifier.statusCode() < 200 || responseUpdateExternalIdentifier.statusCode() >= 300) {
                log.error("Failed to update external identifier for external identifier: " + dduuid);
            }

        } catch (Exception e) {
            log.error("External ID update failed for UUID={} : {}", dduuid, e.getMessage(), e);

            String apiEndpoint = RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.resolveEndpoint(onePamUUID);
            errorLogDAO.logApiError(
                    RecordType.INVOLVED_PARTY,
                    wrapper.getOpsExternalIdentifierVal(),
                    dduuid,
                    null,
                    "Failed to update external identifier: " + e.getMessage(),
                    apiEndpoint,
                    null,
                    null,
                    null, // Batch ID
                    null, // File name
                    wrapper.getFileId()
            );
            apiTransactionLogDAO.logApiFailure(
                    dduuid,
                    wrapper.getFileId(),
                    COFACE_OPS_FLOW,
                    RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.endpoint,
                    RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.method,
                    "API_ERROR",
                    e.getMessage()
            );
            try {
                apiTransactionLogDAO.updateNotificationStatusByUuid(dduuid, wrapper.getFileId());
                log.info("Data_Distributor_Coface_OPS Updated notification status for dd_uuid:{} after organisation creation failure", dduuid);
            } catch (Exception statusEx) {
                log.error("Failed to update notification status for dd_uuid:{}, error:{}", dduuid, statusEx.getMessage());
            }
        }

        CreatePostalAddressRequest postalRequest = new CreatePostalAddressRequest();
        postalRequest.setHouseNumber(wrapper.getPostalAddressHouseNum());
        log.info("HOUSE NUM " + wrapper.getPostalAddressHouseNum());
        log.info("Postal address " + postalRequest.getHouseNumber());
        postalRequest.setPostalCode(wrapper.getPostalAddressPostalCd());
        postalRequest.setCountryCode(wrapper.getPostalAddressCntryCd());
        postalRequest.setHouseNumberAddition(wrapper.getPostalAddressHouseAdd());
        postalRequest.setCityName(wrapper.getPostalAddressCityName());
        postalRequest.setStreetName(wrapper.getPostalAddressStreetNm());
        postalRequest.setUnstructuredAddressLine(wrapper.getAddress());
        postalRequest.setDataSource(DATA_SOURCE);
        try {
            log.info("Data_Distributor_Coface_OU Calling PostalAddress-API for dd_uuid:{}, onePamUuid:{}", dduuid, onePamUUID);

            PostalAddressResponse addr = addressService.createPostalAddress(onePamUUID, postalRequest, wrapper.getFileId());
            if (addr != null) {
                orgUnitAccountingDAO.insertPostalAddrWithWrapper(
                        dduuid,
                        postalRequest.getStreetName(),
                        postalRequest.getHouseNumber(),
                        postalRequest.getHouseNumberAddition(),
                        postalRequest.getPostalCode(),
                        postalRequest.getCityName(),
                        postalRequest.getCountryCode(),
                        postalRequest.getUnstructuredAddressLine(),
                        wrapper.getFileId()
                );
                log.info("Data_Distributor_Coface_OU PostalAddress-API call success for dd_uuid:{}, onePamUuid:{}", dduuid, onePamUUID);
                apiTransactionLogDAO.logApiSuccess(
                        dduuid,
                        wrapper.getFileId(),
                        COFACE_OPS_FLOW,
                        RegkeyEnum.CREATE_POSTAL_ADDRESS.endpoint,
                        RegkeyEnum.CREATE_POSTAL_ADDRESS.method,
                        200
                );
            } else {
                log.warn("Postal address response was null for UUID={}", dduuid);
            }
        } catch (Exception e) {
            log.error("Postal address create failed for UUID={} : {}", dduuid, e.getMessage(), e);
            apiTransactionLogDAO.logApiFailure(
                    dduuid,
                    wrapper.getFileId(),
                    COFACE_OPS_FLOW,
                    RegkeyEnum.CREATE_POSTAL_ADDRESS.endpoint,
                    RegkeyEnum.CREATE_POSTAL_ADDRESS.method,
                    "API_ERROR",
                    e.getMessage()
            );
        }
// ✅ CREATE DIGITAL ADDRESS (EMAIL + PHONE) after postal address and before hierarchy
        try {
            String email = wrapper.getDigitalAddrEmail();
            String phone = wrapper.getDigitalAddrFullTel();

            log.info("Checking digital addresses for dd_uuid:{} email='{}' phone='{}'",
                    dduuid, email, phone);

            // --- EMAIL: BSN_EMAIL ---
            if (email != null && !email.isBlank()) {
                log.info("Creating EMAIL digital address for onePamUuid:{} value:{}", onePamUUID, email);

                CreateDigitalAddressV5Request reqEmail =
                        digitalAddrService.buildCreateRequestForEmail(onePamUUID, email);

                digitalAddrService.createDigitalAddr_OPS(dduuid, onePamUUID, reqEmail);
                apiTransactionLogDAO.logApiSuccess(
                        dduuid,
                        wrapper.getFileId(),
                        COFACE_OPS_FLOW,
                        RegkeyEnum.CREATE_DIGITAL_ADDRESS.endpoint,
                        RegkeyEnum.CREATE_DIGITAL_ADDRESS.method,
                        200
                );
                orgUnitAccountingDAO.updateDigitalAddress_email(dduuid, wrapper.getDigitalAddrFullTel(), wrapper.getFileId());
                log.info("EMAIL digital address created successfully for {}", onePamUUID);
            }

            // --- PHONE: BSN_TEL_NBR ---
            if (phone != null && !phone.isBlank()) {
                log.info("Creating PHONE digital address for onePamUuid:{} value:{}", onePamUUID, phone);

                CreateDigitalAddressV5Request reqPhone =
                        digitalAddrService.buildCreateRequestForPhone(onePamUUID, phone);

                digitalAddrService.createDigitalAddr_OPS(dduuid, onePamUUID, reqPhone);

                apiTransactionLogDAO.logApiSuccess(
                        dduuid,
                        wrapper.getFileId(),
                        COFACE_OPS_FLOW,
                        RegkeyEnum.CREATE_DIGITAL_ADDRESS.endpoint,
                        RegkeyEnum.CREATE_DIGITAL_ADDRESS.method,
                        200
                );
                orgUnitAccountingDAO.updateDigitalAddress_phone(dduuid, wrapper.getDigitalAddrFullTel(), wrapper.getFileId());

                log.info("PHONE digital address created successfully for {}", onePamUUID);
            }

            // Nothing provided
            if ((email == null || email.isBlank()) && (phone == null || phone.isBlank())) {
                log.info("No digital address (email/phone) provided for onePamUuid:{}, skipping.", onePamUUID);
            }

        } catch (Exception e) {
            log.error("Digital address creation failed for dd_uuid={} : {}", dduuid, e.getMessage(), e);

            apiTransactionLogDAO.logApiFailure(
                    dduuid,
                    wrapper.getFileId(),
                    COFACE_OPS_FLOW,
                    RegkeyEnum.CREATE_DIGITAL_ADDRESS.endpoint,
                    RegkeyEnum.CREATE_DIGITAL_ADDRESS.method,
                    "API_ERROR",
                    e.getMessage()
            );
        }
            final String leNumber = wrapper.getOrgExternalIdentifierVal();
            if (leNumber == null || leNumber.isBlank()) {
                log.warn("LE number is null/blank in wrapper for opsUUID={}. Skipping hierarchy creation.", wrapper.getOpsUUID());
            } else {
                final String orgDdUuid = mappingDAO.findParentUUIDByExternalIdentifier(leNumber);
                log.info("Resolved ORG DD_UUID '{}' for LE number '{}'", orgDdUuid, leNumber);

                if (orgDdUuid == null || orgDdUuid.isBlank()) {
                    log.warn("No DD_UUID found for LE/ORG_NUMBER='{}'. Skipping hierarchy.", leNumber);
                } else {
                    var orgSearch = involvedPartySearchService
                            .searchInvolvedPartyByInternalIdentifier("organisation", "CSI_BE", orgDdUuid, wrapper.getFileId());

                    if (orgSearch == null ||
                            orgSearch.getOrganisations() == null ||
                            orgSearch.getOrganisations().isEmpty()) {

                        log.warn("No OnePAM organisation found for internal identifier [type=CSI_BE, value={}]. Skipping hierarchy.", orgDdUuid);

                    } else {

                        String parentId = orgSearch.getOrganisations().get(0).getInvolvedPartyIdentifier();

                        if (parentId == null || parentId.isBlank()) {
                            log.warn("Organisation found but missing involvedPartyIdentifier [CSI_BE={}].", orgDdUuid);
                        } else {
                            try {
                                log.info("Calling Hierarchy-API for dd_uuid:{}, child:{}, parent:{}",
                                        dduuid, onePamUUID, parentId);

                                Response hierResp = createOrganisationUnitHierarchy(onePamUUID, parentId);

                                apiTransactionLogDAO.logApiSuccess(
                                        dduuid,
                                        wrapper.getFileId(),
                                        COFACE_OPS_FLOW,
                                        RegkeyEnum.CREATE_ORGANISATION_UNIT_HIERARCHY.endpoint,
                                        RegkeyEnum.CREATE_ORGANISATION_UNIT_HIERARCHY.method,
                                        200
                                );

                                log.info("Hierarchy-API call success for dd_uuid:{}, child:{}, parent:{}",
                                        dduuid, onePamUUID, parentId);

                            } catch (Exception e) {
                                log.error("Hierarchy create failed for UUID={} : {}", dduuid, e.getMessage(), e);

                                apiTransactionLogDAO.logApiFailure(
                                        dduuid,
                                        wrapper.getFileId(),
                                        COFACE_OPS_FLOW,
                                        RegkeyEnum.CREATE_ORGANISATION_UNIT_HIERARCHY.endpoint,
                                        RegkeyEnum.CREATE_ORGANISATION_UNIT_HIERARCHY.method,
                                        "API_ERROR",
                                        e.getMessage()
                                );
                            }
                        }
                    }
                }


            try {
                apiTransactionLogDAO.updateNotificationStatusByUuid(dduuid, wrapper.getFileId());
                log.info("Data_Distributor_Coface_OPS Updated notification status for dd_uuid:{} after organisation creation failure", dduuid);
            } catch (Exception statusEx) {
                log.error("Failed to update notification status for dd_uuid:{}, error:{}", dduuid, statusEx.getMessage());
            }
        }
        log.info("Data_Distributor_Coface_OU update accounting/tracking Table completed...!");
    }

    private CreateInvolvedPartyResponseV5 createOrganisationUnit(String dd_uuid, OrganisationUnitDomainWrapper wrapper) {
        String organisationUnitName = configReader.fetchOrganisationUnitName(dd_uuid);

        Map<String, String> config = getConfig(dd_uuid);
        CreateInvolvedPartyRequestV5 request = CreateInvolvedPartyRequestV5.builder()
                .organisationUnit(
                        CreateOrganisationUnitRequest.builder()
                                .dataSource(DATA_SOURCE)
                                .logicalDataDomain(LOGICAL_DATA_DOMAIN)
                                .countryOfResidence(wrapper.getPostalAddressCntryCd())
                                .preferredLanguage(PREFERRED_LANGUAGE)
                                .channelOfEntry(CHANNEL_OF_ENTRY)
                                .organisationUnitStructureType(STRUCTURE_TYPE)
                                .effectiveDate("2025-09-02T00:30:11.537+02:00")
                                .involvedPartyInternalIdentifiers(Collections.singletonList(
                                        CreateInternalIdentifierRequest.builder()
                                                .involvedPartyInternalIdentifierType("CSI_BE")
                                                .involvedPartyInternalIdentifierValue(dd_uuid)
                                                .build()))
                                .organisationUnitNames(Collections.singletonList(
                                        CreateOrganisationUnitNameRequest.builder()
                                                .organisationUnitNameType(ORGANISATION_UNIT_NAME_TYPE)
                                                .organisationUnitName(organisationUnitName)
                                                .dataSource(DATA_SOURCE)
                                                .build()))
                                .build())
                .build();
        try {
            log.info("Data_Distributor_Coface_OU Calling Create-OrganisationUnit-Api for dd_uuid:{}", dd_uuid);

            CreateInvolvedPartyResponseV5 responseV5 = invPartyOnePamRepository.createInvolvedParty(request).get();

            log.info("Data_Distributor_Coface_OU Create-OrganisationUnit-Api call Success for dd_uuid:{}", dd_uuid);
            return responseV5;
        } catch (Exception e) {
            log.error("Failed to create organisation unit for uuid={}: {}", dd_uuid, e.getMessage(), e);
            throw new RuntimeException(e);
        }
    }

    private UpdateExternalIdentifierInvolvedPartyRequest buildUpdateRequest(String uuid, OrganisationUnitDomainWrapper wrapper) {
        Map<String, String> config = getConfig(uuid);
        return UpdateExternalIdentifierInvolvedPartyRequest.builder()
                .involvedPartyExternalIdentifierType(EXTERNAL_ID_TYPE_KBO)
                .involvedPartyExternalIdentifierValue(config.get("opsNumber"))
                .effectiveDate(OnePamDateUtil.toOnePamDate(wrapper.getOpsExtIdDateOfIssue()))
                .dateOfIssue(wrapper.getOpsExtIdDateOfIssue())
                .dataSource(DATA_SOURCE)
                .build();
    }

    private Response createOrganisationUnitHierarchy(String childId, String parentId) {
        OrganisationUnitOrganisationRelationshipRequest relationshipRequest =
                OrganisationUnitOrganisationRelationshipRequest.builder()
                        .childOrganisationUnitIdentifier(childId)
                        .parentOrganisationIdentifier(parentId)
                        .parentRoleReasonType("CPTL_CTRL")
                        .dataSource(DATA_SOURCE)
                        .build();

        OrganisationUnitOrganisationRelationshipRequestV1 wrapper =
                OrganisationUnitOrganisationRelationshipRequestV1.builder()
                        .organisationUnitOrganisationRelationship(relationshipRequest)
                        .build();

        try {
            Response response = organisationUnitOnePamRepository.createOrganisationUnitHierarchy(wrapper).get();
            log.info("Successfully created hierarchy between child: {} and parent: {}", childId, parentId);

            return response;
        } catch (Exception e) {
            log.error("Failed to create organisation unit hierarchy", e);
            throw new RuntimeException("Hierarchy creation failed", e);
        }
    }

    private Map<String, String> getConfig(String uuid) {
        try {
            List<Map<String, String>> list = configReader.fetchByOpsNumber(uuid);
            return list.isEmpty() ? Collections.emptyMap() : list.get(0);
        } catch (Exception e) {
            e.printStackTrace();
            throw e;
        }
    }
}
