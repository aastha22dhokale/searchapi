package com.ing.datadist.api.service;

import com.ing.datadist.api.exception.DataDistributionApiException;
import com.ing.datadist.api.model.*;
import com.ing.datadist.api.utils.DataDistributionConstants;
import com.ing.datadist.api.utils.RegkeyEnum;
import com.ing.datadist.dao.ApiTransactionLogDAO;
import com.ing.datadist.dao.ErrorLogDAO;
import com.ing.datadist.dao.MappingDAO;
import com.ing.datadist.dao.OrgParentAccountingDAO;
import com.ing.datadist.domain.LegalEntityParentDomain;
import com.ing.datadist.enums.RecordType;
import com.ing.datadist.kafka.util.EventTransactionType;
import com.ing.datadist.kafka.util.NotificationStatus;
import com.ing.datadist.kafka.util.NotificationType;
import lombok.NonNull;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.ArrayList;
import java.util.List;
import java.util.Objects;
import java.util.Optional;

import static com.ing.datadist.api.utils.DataDistributionConstants.COFACE_LE_PARENT_FLOW;

@Service
@Slf4j
public class UpdateOrganisationParentService {

    private static final String DIGITAL_ADDR_FULL_TEL = "BSN_TEL_NBR";
    private static final String EXT_IDENTIFIER_TYPE_NSSO = "NSSO_EMP_ID_BE";
    private static final String VAT_ASSMT_TYPE = "GKYC_CL";

    private final InvolvedPartyOnePamRepository involvedPartyOnePamRepository;
    private final OrganisationOnePamRepository organisationOnePamRepository;
    private final AddressService addressService;
    private final SoftClosePostalAddressService softClosePostalAddressService;
    private final OrganisationNameService organisationNameService;
    private final DigitalAddrService digitalAddrService;
    private final OrganisationAssessmentService organisationAssessmentService;

    private final OrganisationService organisationService;

    private final OrgParentAccountingDAO orgParentAccountingDAO;
    private final ApiTransactionLogDAO apiTransactionLogDAO;
    private final ErrorLogDAO errorLogDAO;

    @Autowired
    MappingDAO mappingDAO;

    public UpdateOrganisationParentService(InvolvedPartyOnePamRepository involvedPartyOnePamRepository,
                                           OrganisationOnePamRepository organisationOnePamRepository,
                                           AddressService addressService,
                                           SoftClosePostalAddressService softCloseService,
                                           OrganisationNameService organisationNameService,
                                           DigitalAddrService digitalAddrService,
                                           OrgParentAccountingDAO accountingDao,
                                           OrganisationService organisationService,
                                           OrganisationAssessmentService organisationAssessmentService,
                                           ApiTransactionLogDAO apiTransactionLogDAO,
                                           ErrorLogDAO errorLogDAO) {
        this.involvedPartyOnePamRepository = involvedPartyOnePamRepository;
        this.organisationOnePamRepository = organisationOnePamRepository;
        this.addressService = addressService;
        this.softClosePostalAddressService = softCloseService;
        this.organisationNameService = organisationNameService;
        this.digitalAddrService = digitalAddrService;
        this.orgParentAccountingDAO = accountingDao;
        this.organisationAssessmentService = organisationAssessmentService;
        this.organisationService = organisationService;
        this.apiTransactionLogDAO = apiTransactionLogDAO;
        this.errorLogDAO = errorLogDAO;
    }

    public void updateOrganisation(LegalEntityParentDomain wrapper,
                                   SearchInvolvedPartiesResponseV1 response,
                                   ExternalIdentifiersResponseV5 externalIdentifiersResponse,
                                   AssessmentsResponseV5 assessmentsResponse,
                                   @NonNull Boolean apiFlag,
                                   List<LegalEntityParentDomain> oilUpdateParentWrappers) throws Exception {

        List<SearchOrganisationResponseV1> organisations = response.getOrganisations();
        List<SearchOrganisationUnitAddressResponseV1> postalAddresses;
        List<SearchOrganisationNameResponseV1> organisationNames;
        List<SearchOrganisationUnitDigitalAddressesV1> digitalAddresses;
        List<SearchOrganisationUnitExternalIdentifierResponseV1> externalIdentifiers;
        List<InvolvedPartyExternalIdentifierResponseV5> involvedPartyExternalIdentifiers;
        List<AssessmentResponseV5> assessments;

        String ddUuid = wrapper.getOrgUUID();


        for (SearchOrganisationResponseV1 organisation : organisations) {
            String onePamUUID = organisation.getInvolvedPartyIdentifier();

            organisationNames = Optional.ofNullable(organisation.getOrganisationNames()).orElse(new ArrayList<>());
            postalAddresses = Optional.ofNullable(organisation.getPostalAddresses()).orElse(new ArrayList<>());
            digitalAddresses = Optional.ofNullable(organisation.getDigitalAddresses()).orElse(new ArrayList<>());
            externalIdentifiers = Optional.ofNullable(organisation.getInvolvedPartyExternalIdentifiers()).orElse(new ArrayList<>());
            involvedPartyExternalIdentifiers = Optional.ofNullable(externalIdentifiersResponse.getInvolvedPartyExternalIdentifiers()).orElse(new ArrayList<>());
            assessments = Optional.ofNullable(assessmentsResponse.getAssessments()).orElse(new ArrayList<>());

            LegalEntityParentDomain updateLegalEntityParentDomain = new LegalEntityParentDomain();
            updateLegalEntityParentDomain.setOrgUUID(ddUuid);

            log.info("organisation ddUuid:{}, onePamUUID:{}, organisationUnitNamesSize:{}, postalAddressesSize:{}, " +
                            "digitalAddressesSize:{}, externalIdentifiers:{}",
                    ddUuid, onePamUUID, organisationNames.size(),
                    postalAddresses.size(), digitalAddresses.size(), externalIdentifiers.size());

            boolean lePatchApiFlag = false;
            boolean lePatchOilFlag = false;

            try{
                orgParentAccountingDAO.saveSearchResponseToDB(ddUuid, organisation);
            }
            catch (Exception ex){
                errorLogDAO.logDatabaseError(RecordType.ORGANISATION_CHILD, wrapper.getLeExternalIdentifier(), ddUuid, "FAILED TO SAVE ONEPAM DATA INTO DATABASE : ONEPAM COLUMNS", null, wrapper.getFileName(), null, wrapper.getFileId());
                return;
            }

            if (wrapper.getOrgStatus() != null && !wrapper.getOrgStatus().isEmpty()
                    && organisation.getOrganisationLifeCycleStatusType() != null
                    && !Objects.equals(wrapper.getOrgStatus(), organisation.getOrganisationLifeCycleStatusType())) {
                log.info("OrgStatus changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                        ddUuid, onePamUUID, wrapper.getOrgStatus(), organisation.getOrganisationLifeCycleStatusType());
                if (apiFlag) {
                    lePatchApiFlag = true;
                } else {
                    lePatchOilFlag =  true;
                    updateLegalEntityParentDomain.setOrgStatus(wrapper.getOrgStatus());
                }
            }

            if (wrapper.getOrgLegalForm() != null && !wrapper.getOrgLegalForm().isEmpty()
                    && organisation.getLegalForm() != null
                    && !Objects.equals(wrapper.getOrgLegalForm(), organisation.getLegalForm())) {
                log.info("OrgLegalForm changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                        ddUuid, onePamUUID, wrapper.getOrgLegalForm(), organisation.getLegalForm());
                if (apiFlag) {
                    lePatchApiFlag = true;
                } else {
                    lePatchOilFlag =  true;
                    updateLegalEntityParentDomain.setOrgLegalForm(wrapper.getOrgLegalForm());
                }
            }

            if (wrapper.getOrgBusinessClosedownDate() != null && !wrapper.getOrgBusinessClosedownDate().isEmpty()
                    && organisation.getBusinessClosedDownDate() != null
                    && !Objects.equals(wrapper.getOrgBusinessClosedownDate(), organisation.getBusinessClosedDownDate())) {
                log.info("OrgBusinessClosedownDate changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                        ddUuid, onePamUUID, wrapper.getOrgBusinessClosedownDate(), organisation.getBusinessClosedDownDate());
                if (apiFlag) {
                    lePatchApiFlag = true;
                } else {
                    lePatchOilFlag =  true;
                    updateLegalEntityParentDomain.setOrgBusinessClosedownDate(wrapper.getOrgBusinessClosedownDate());
                }
            }

            if (wrapper.getLELegalStatus() != null && !wrapper.getLELegalStatus().isEmpty()
                    && organisation.getFinancialLegalStatusType() != null
                    && !Objects.equals(wrapper.getLELegalStatus(), organisation.getFinancialLegalStatusType())) {
                log.info("LELegalStatus changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                        ddUuid, onePamUUID, wrapper.getLELegalStatus(), organisation.getFinancialLegalStatusType());
                if (apiFlag) {
                    lePatchApiFlag = true;
                } else {
                    lePatchOilFlag =  true;
                    updateLegalEntityParentDomain.setLELegalStatus(wrapper.getLELegalStatus());
                }
            }

            if (wrapper.getLEPreferredLanguage() != null && !wrapper.getLEPreferredLanguage().isEmpty()
                    && organisation.getPreferredLanguage() != null
                    && !Objects.equals(wrapper.getLEPreferredLanguage(), organisation.getPreferredLanguage())) {
                log.info("LEPreferredLanguage changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                        ddUuid, onePamUUID, wrapper.getLEPreferredLanguage(), organisation.getPreferredLanguage());
                if (apiFlag) {
                    lePatchApiFlag = true;
                } else {
                    lePatchOilFlag =  true;
                    updateLegalEntityParentDomain.setLEPreferredLanguage(wrapper.getLEPreferredLanguage());
                }
            }

            if(lePatchOilFlag){
                try {
                    mappingDAO.insertEventTrack(ddUuid, NotificationType.LEGAL_ENTITY.value(),
                            EventTransactionType.UPDATE_ORGANISATION.getLabel(), NotificationStatus.EXPECTED.name(), null);
                } catch (Exception ex) {
                    log.info("Organisation update failed while insertEventTrack for lePatchOilFlag , for ddUuid:{}, " +
                            "error:{}", ddUuid, ex.getMessage());
                }
            }

            if (apiFlag && lePatchApiFlag) {
                try {
                    GetInvolvedPartyResponseV6 updateResp = organisationService.updateOrganisation(onePamUUID, wrapper);
                    orgParentAccountingDAO.updFullOrganisation(updateResp);

                    apiTransactionLogDAO.logApiSuccess(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.UPDATE_INVOLVED_PARTY.endpoint,
                            RegkeyEnum.UPDATE_INVOLVED_PARTY.method,
                            200
                    );

                    log.info("Organisation update successful for ddUuid:{}, onePamUUID:{}; response:{}",
                            ddUuid, onePamUUID, updateResp);

                } catch (Exception ex) {
                    apiTransactionLogDAO.logApiFailure(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.UPDATE_INVOLVED_PARTY.endpoint,
                            RegkeyEnum.UPDATE_INVOLVED_PARTY.method,
                            "API_ERROR",
                            ex.getMessage()
                    );
                    log.error("Organisation update failed for ddUuid:{}, onePamUUID:{}; error:{}",
                            ddUuid, onePamUUID, ex.getMessage(), ex);
                    errorLogDAO.logApiError(
                            RecordType.ORGANISATION_PARENT,
                            wrapper.getLeExternalIdentifier(),
                            ddUuid,
                            null,
                            "Organisation update failed: " + extractInnerMessage(ex),
                            RegkeyEnum.UPDATE_INVOLVED_PARTY.endpoint,
                            null,
                            null,
                            null,
                            wrapper.getFileName(),
                            wrapper.getFileId()
                    );
                }
            }

            // ---- Names ----
            for (SearchOrganisationNameResponseV1 name : organisationNames) {
                String type = name.getOrganisationNameType();
                String onePamName = name.getOrganisationName();

                if ("LGL_NM".equals(type)) {
                    if (wrapper.getOrgName() != null && !wrapper.getOrgName().isBlank()
                            && onePamName != null
                            && !Objects.equals(wrapper.getOrgName(), onePamName)) {
                        log.info("Primary name changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                                ddUuid, onePamUUID, wrapper.getOrgName(), onePamName);

                        if (apiFlag) {
                            try {
                                UpdateOrganisationNameResponse resp =
                                        organisationNameService.updateOrganisationName(
                                                onePamUUID,
                                                onePamName,
                                                wrapper.getOrgName(),
                                                DataDistributionConstants.LGL_NM,
                                                wrapper.getFileId()
                                        );

                                apiTransactionLogDAO.logApiSuccess(
                                        ddUuid,
                                        wrapper.getFileId(),
                                        COFACE_LE_PARENT_FLOW,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.endpoint,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.method,
                                        200
                                );

                                orgParentAccountingDAO.updateOrganisationName(
                                        ddUuid,
                                        resp.getOrganisationName().getOrganisationName(),
                                        wrapper.getFileId()
                                );

                            } catch (Exception ex) {
                                log.error("Primary name update failed ddUuid:{}, onePamUUID:{}, error:{}",
                                        ddUuid, onePamUUID, ex.getMessage());

                                apiTransactionLogDAO.logApiFailure(
                                        ddUuid,
                                        wrapper.getFileId(),
                                        COFACE_LE_PARENT_FLOW,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.endpoint,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.method,
                                        "API_ERROR",
                                        ex.getMessage()
                                );
                                errorLogDAO.logApiError(
                                        RecordType.ORGANISATION_PARENT,
                                        wrapper.getLeExternalIdentifier(),
                                        ddUuid,
                                        null,
                                        "Organisation name update failed: " + extractInnerMessage(ex),
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.endpoint,
                                        null,
                                        null,
                                        null,
                                        wrapper.getFileName(),
                                        wrapper.getFileId()
                                );
                            }
                        } else {
                            try {
                                mappingDAO.insertEventTrack(ddUuid, NotificationType.LEGAL_ENTITY_NAME.value(),
                                        EventTransactionType.UPDATE_ORG_NAME.getLabel(), NotificationStatus.EXPECTED.name(), null);
                            } catch (Exception ex) {
                                log.info("Organisation update failed while insertEventTrack for UPDATE_ORG_NAME , for ddUuid:{}, " +
                                        "error:{}", ddUuid, ex.getMessage());
                            }
                            updateLegalEntityParentDomain.setOrgName(wrapper.getOrgName());
                        }
                    }
                    continue;
                }

                if ("LGL_NM_SHRT".equals(type)) {
                    if (wrapper.getOrgOtherName() != null && !wrapper.getOrgOtherName().isBlank()
                            && onePamName != null
                            && !Objects.equals(wrapper.getOrgOtherName(), onePamName)) {
                        log.info("Short name changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                                ddUuid, onePamUUID, wrapper.getOrgOtherName(), onePamName);

                        if (apiFlag) {
                            try {
                                UpdateOrganisationNameResponse resp =
                                        organisationNameService.updateOrganisationName(
                                                onePamUUID,
                                                onePamName,
                                                wrapper.getOrgOtherName(),
                                                DataDistributionConstants.LGL_NM_SHRT,
                                                wrapper.getFileId()
                                        );

                                apiTransactionLogDAO.logApiSuccess(
                                        ddUuid,
                                        wrapper.getFileId(),
                                        COFACE_LE_PARENT_FLOW,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.endpoint,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.method,
                                        200
                                );

                                orgParentAccountingDAO.updateOrganisationOtherName(
                                        ddUuid,
                                        resp.getOrganisationName().getOrganisationName(),
                                        wrapper.getFileId()
                                );

                            } catch (Exception ex) {
                                log.error("Short name update failed ddUuid:{}, onePamUUID:{}, error:{}",
                                        ddUuid, onePamUUID, ex.getMessage());

                                apiTransactionLogDAO.logApiFailure(
                                        ddUuid,
                                        wrapper.getFileId(),
                                        COFACE_LE_PARENT_FLOW,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.endpoint,
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.method,
                                        "API_ERROR",
                                        ex.getMessage()
                                );
                                errorLogDAO.logApiError(
                                        RecordType.ORGANISATION_PARENT,
                                        wrapper.getLeExternalIdentifier(),
                                        ddUuid,
                                        null,
                                        "Organisation name update failed: " + extractInnerMessage(ex),
                                        RegkeyEnum.UPDATE_ORGANISATION_NAME.endpoint,
                                        null,
                                        null,
                                        null,
                                        wrapper.getFileName(),
                                        wrapper.getFileId()
                                );

                            }
                        } else {
                            try {
                                mappingDAO.insertEventTrack(ddUuid, NotificationType.LEGAL_ENTITY_NAME.value(),
                                        EventTransactionType.UPDATE_ORG_NAME.getLabel(), NotificationStatus.EXPECTED.name(), null);
                            } catch (Exception ex) {
                                log.info("Organisation update failed while insertEventTrack for UPDATE_ORG_NAME OtherName , for ddUuid:{}, " +
                                        "error:{}", ddUuid, ex.getMessage());
                            }
                            updateLegalEntityParentDomain.setOrgOtherName(wrapper.getOrgOtherName());
                        }
                    }
                    continue;
                }

                log.info("Name type not relevant (expected LGL_NM/LGL_NM_SHRT). Found '{}'", type);
            }

            // ---- Postal Address ----
            boolean postalAddressHasChangedApiFlag = false;
            boolean postalAddressHasChangedOilFlag = false;

            for (SearchOrganisationUnitAddressResponseV1 address : postalAddresses) {

                if (wrapper.getAdrPostalAddressStreetName() != null && !wrapper.getAdrPostalAddressStreetName().isEmpty()
                        && address.getStreetName() != null
                        && !Objects.equals(wrapper.getAdrPostalAddressStreetName(), address.getStreetName())) {
                    log.info("StreetName changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                            ddUuid, onePamUUID, wrapper.getAdrPostalAddressStreetName(), address.getStreetName());
                    if (apiFlag) {
                        postalAddressHasChangedApiFlag = true;
                    } else {
                        postalAddressHasChangedOilFlag = true;
                        updateLegalEntityParentDomain.setAdrPostalAddressStreetName(wrapper.getAdrPostalAddressStreetName());
                    }
                }

                if (wrapper.getAdrPostalAddressHouseNum() != null && !wrapper.getAdrPostalAddressHouseNum().isEmpty()
                        && address.getHouseNumber() != null
                        && !Objects.equals(wrapper.getAdrPostalAddressHouseNum(), address.getHouseNumber())) {
                    log.info("HouseNum changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                            ddUuid, onePamUUID, wrapper.getAdrPostalAddressHouseNum(), address.getHouseNumber());
                    if (apiFlag) {
                        postalAddressHasChangedApiFlag = true;
                    } else {
                        postalAddressHasChangedOilFlag = true;
                        updateLegalEntityParentDomain.setAdrPostalAddressHouseNum(wrapper.getAdrPostalAddressHouseNum());
                    }
                }

                if (wrapper.getAdrPostalAddressHouseNumAdd() != null && !wrapper.getAdrPostalAddressHouseNumAdd().isEmpty()
                        && address.getHouseNumberAddition() != null
                        && !Objects.equals(wrapper.getAdrPostalAddressHouseNumAdd(), address.getHouseNumberAddition())) {
                    log.info("HouseNumAdd changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                            ddUuid, onePamUUID, wrapper.getAdrPostalAddressHouseNumAdd(), address.getHouseNumberAddition());
                    if (apiFlag) {
                        postalAddressHasChangedApiFlag = true;
                    } else {
                        postalAddressHasChangedOilFlag = true;
                        updateLegalEntityParentDomain.setAdrPostalAddressHouseNumAdd(wrapper.getAdrPostalAddressHouseNumAdd());
                    }
                }

                if (wrapper.getAdrPostalAddressPostalCode() != null && !wrapper.getAdrPostalAddressPostalCode().isEmpty()
                        && address.getPostalCode() != null
                        && !Objects.equals(wrapper.getAdrPostalAddressPostalCode(), address.getPostalCode())) {
                    log.info("PostalCode changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                            ddUuid, onePamUUID, wrapper.getAdrPostalAddressPostalCode(), address.getPostalCode());
                    if (apiFlag) {
                        postalAddressHasChangedApiFlag = true;
                    } else {
                        postalAddressHasChangedOilFlag = true;
                        updateLegalEntityParentDomain.setAdrPostalAddressPostalCode(wrapper.getAdrPostalAddressPostalCode());
                    }
                }

                if (wrapper.getAdrPostalAddressCityName() != null && !wrapper.getAdrPostalAddressCityName().isEmpty()
                        && address.getCityName() != null
                        && !Objects.equals(wrapper.getAdrPostalAddressCityName(), address.getCityName())) {
                    log.info("CityName changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                            ddUuid, onePamUUID, wrapper.getAdrPostalAddressCityName(), address.getCityName());
                    if (apiFlag) {
                        postalAddressHasChangedApiFlag = true;
                    } else {
                        postalAddressHasChangedOilFlag = true;
                        updateLegalEntityParentDomain.setAdrPostalAddressCityName(wrapper.getAdrPostalAddressCityName());
                    }
                }

                if (wrapper.getAdrPostalAddressCountryCode() != null && !wrapper.getAdrPostalAddressCountryCode().isEmpty()
                        && address.getCountryCode() != null
                        && !Objects.equals(wrapper.getAdrPostalAddressCountryCode(), address.getCountryCode())) {
                    log.info("CountryCode changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                            ddUuid, onePamUUID, wrapper.getAdrPostalAddressCountryCode(), address.getCountryCode());
                    if (apiFlag) {
                        postalAddressHasChangedApiFlag = true;
                    } else {
                        postalAddressHasChangedOilFlag = true;
                        updateLegalEntityParentDomain.setAdrPostalAddressCountryCode(wrapper.getAdrPostalAddressCountryCode());
                    }
                }

                if (wrapper.getAdrUnstructuredAddress() != null && !wrapper.getAdrUnstructuredAddress().isEmpty()
                        && address.getUnstructuredAddressLine1() != null
                        && !Objects.equals(wrapper.getAdrUnstructuredAddress(), address.getUnstructuredAddressLine1())) {
                    log.info("UnstructuredAddress changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                            ddUuid, onePamUUID, wrapper.getAdrUnstructuredAddress(), address.getUnstructuredAddressLine1());
                    if (apiFlag) {
                        postalAddressHasChangedApiFlag = true;
                    } else {
                        postalAddressHasChangedOilFlag = true;
                        updateLegalEntityParentDomain.setAdrUnstructuredAddress(wrapper.getAdrUnstructuredAddress());
                    }
                }
            }

            if (postalAddressHasChangedOilFlag) {
                try {
                    mappingDAO.insertEventTrack(ddUuid, NotificationType.LEGAL_ENTITY_POSTAL_ADDRESS.value(),
                            EventTransactionType.UPDATE_ORG_POSTAL_ADDRESS.getLabel(), NotificationStatus.EXPECTED.name(), null);
                } catch (Exception ex) {
                    log.info("Organisation update failed while insertEventTrack for UPDATE_ORG_POSTAL_ADDRESS , for ddUuid:{}, " +
                            "error:{}", ddUuid, ex.getMessage());
                }
            }

            if (postalAddressHasChangedApiFlag && apiFlag) {
                CreatePostalAddressRequest postalRequest = new CreatePostalAddressRequest();
                postalRequest.setStreetName(wrapper.getAdrPostalAddressStreetName());
                postalRequest.setHouseNumber(wrapper.getAdrPostalAddressHouseNum());
                postalRequest.setHouseNumberAddition(wrapper.getAdrPostalAddressHouseNumAdd());
                postalRequest.setPostalCode(wrapper.getAdrPostalAddressPostalCode());
                postalRequest.setCityName(wrapper.getAdrPostalAddressCityName());
                postalRequest.setUnstructuredAddressLine(wrapper.getAdrUnstructuredAddress());
                postalRequest.setCountryCode(
                        Optional.ofNullable(wrapper.getAdrPostalAddressCountryCode())
                                .filter(s -> !s.isBlank())
                                .orElse("BE"));

                // Soft close + Create
                try {
                    SoftClosePostalAddressRequest softCloseRequest = new SoftClosePostalAddressRequest();
                    softClosePostalAddressService.softClose(onePamUUID, softCloseRequest, wrapper.getFileId());
                    log.info("Soft close success for uuid: {}", onePamUUID);
                    apiTransactionLogDAO.logApiSuccess(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.SOFT_CLOSE_POSTAL_ADDRESS.endpoint,
                            RegkeyEnum.SOFT_CLOSE_POSTAL_ADDRESS.method,
                            200
                    );
                } catch (Exception e) {
                    log.error("Soft-close failed for UUID={} : {}", onePamUUID, e.getMessage(), e);
                    apiTransactionLogDAO.logApiFailure(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.SOFT_CLOSE_POSTAL_ADDRESS.endpoint,
                            RegkeyEnum.SOFT_CLOSE_POSTAL_ADDRESS.method,
                            "API_ERROR",
                            e.getMessage()
                    );
                    errorLogDAO.logApiError(
                            RecordType.ORGANISATION_PARENT,
                            wrapper.getLeExternalIdentifier(),
                            ddUuid,
                            null,
                            "soft close postal address failed: " + extractInnerMessage(e),
                            RegkeyEnum.SOFT_CLOSE_POSTAL_ADDRESS.endpoint,
                            null,
                            null,
                            null,
                            wrapper.getFileName(),
                            wrapper.getFileId()
                    );
                }

                try {
                    log.info("Calling PostalAddress-API for dd_uuid:{}, onePamUuid:{}", ddUuid, onePamUUID);

                    PostalAddressResponse addr = addressService.createPostalAddress(onePamUUID, postalRequest,
                            wrapper.getFileId());
                    if (addr != null) {
                        log.info("PostalAddress-API success for dd_uuid:{}, onePamUuid:{}", ddUuid, onePamUUID);
                        apiTransactionLogDAO.logApiSuccess(
                                ddUuid,
                                wrapper.getFileId(),
                                COFACE_LE_PARENT_FLOW,
                                RegkeyEnum.CREATE_POSTAL_ADDRESS.endpoint,
                                RegkeyEnum.CREATE_POSTAL_ADDRESS.method,
                                200
                        );

                        orgParentAccountingDAO.updatePostalAddrWithWrapperLE(
                                ddUuid,
                                postalRequest.getStreetName(),
                                postalRequest.getHouseNumber(),
                                postalRequest.getHouseNumberAddition(),
                                postalRequest.getPostalCode(),
                                postalRequest.getCityName(),
                                postalRequest.getCountryCode(),
                                postalRequest.getUnstructuredAddressLine(),
                                wrapper.getFileId()
                        );
                    } else {
                        log.warn("Postal address response was null for ddUuid={}", ddUuid);
                    }
                } catch (Exception e) {
                    log.error("Postal address create failed for ddUuid={} : {}", ddUuid, e.getMessage(), e);
                    apiTransactionLogDAO.logApiFailure(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.CREATE_POSTAL_ADDRESS.endpoint,
                            RegkeyEnum.CREATE_POSTAL_ADDRESS.method,
                            "API_ERROR",
                            e.getMessage()
                    );
                    errorLogDAO.logApiError(
                            RecordType.ORGANISATION_PARENT,
                            wrapper.getLeExternalIdentifier(),
                            ddUuid,
                            null,
                            "create postal address failed: " + extractInnerMessage(e),
                            RegkeyEnum.CREATE_POSTAL_ADDRESS.endpoint,
                            null,
                            null,
                            null,
                            wrapper.getFileName(),
                            wrapper.getFileId()
                    );
                }

            } else if (apiFlag) {
                // No content changes—just verification update
                try {
                    var verificationReq = UpdatePostalAddressRequestV5.builder()
                            .lastVerificationDate(java.time.OffsetDateTime.now().toString())
                            .build();

                    addressService.updatePostalAddress(onePamUUID, "BSN_ADR", verificationReq, wrapper.getFileId());
                    apiTransactionLogDAO.logApiSuccess(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.UPDATE_POSTAL_ADDRESS.endpoint,
                            RegkeyEnum.UPDATE_POSTAL_ADDRESS.method,
                            200
                    );

                } catch (Exception e) {
                    log.error("Postal address verification failed for ddUuid={} : {}", ddUuid, e.getMessage(), e);
                    apiTransactionLogDAO.logApiFailure(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.UPDATE_POSTAL_ADDRESS.endpoint,
                            RegkeyEnum.UPDATE_POSTAL_ADDRESS.method,
                            "API_ERROR",
                            e.getMessage()
                    );
                    errorLogDAO.logApiError(
                            RecordType.ORGANISATION_PARENT,
                            wrapper.getLeExternalIdentifier(),
                            ddUuid,
                            null,
                            "postal address update failed: " + extractInnerMessage(e),
                            RegkeyEnum.UPDATE_POSTAL_ADDRESS.endpoint,
                            null,
                            null,
                            null,
                            wrapper.getFileName(),
                            wrapper.getFileId()
                    );
                }
            }

            // ---- Digital Address (phone) ----
            // ---- Digital Address (phone) ----
            for (SearchOrganisationUnitDigitalAddressesV1 digitalAddress : digitalAddresses) {
                String fullDigitalAddress = digitalAddress.getFullDigitalAddress();

                if (DIGITAL_ADDR_FULL_TEL.equalsIgnoreCase(digitalAddress.getDigitalAddressUsageType())) {

                    boolean changed = wrapper.getAdrDigitalAddrFullTel() != null
                            && !wrapper.getAdrDigitalAddrFullTel().isBlank()
                            && fullDigitalAddress != null
                            && !Objects.equals(wrapper.getAdrDigitalAddrFullTel(), fullDigitalAddress);

                    if (changed) {
                        log.info("DigitalAddrFullTel changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                                ddUuid, onePamUUID, wrapper.getAdrDigitalAddrFullTel(), fullDigitalAddress);

                        if (!apiFlag) {
                            try {
                                mappingDAO.insertEventTrack(ddUuid, NotificationType.ORGANISATION_UNIT_DIGITAL_ADDRESS.value(),
                                        EventTransactionType.UPDATE_ORG_DIGITAL_ADDRESS.getLabel(), NotificationStatus.EXPECTED.name(), null);
                            } catch (Exception ex) {
                                log.info("Organisation update failed while insertEventTrack for UPDATE_ORG_DIGITAL_ADDRESS , for ddUuid:{}, " +
                                        "error:{}", ddUuid, ex.getMessage());
                            }
                            updateLegalEntityParentDomain.setAdrDigitalAddrFullTel(wrapper.getAdrDigitalAddrFullTel());
                        }
                        if (apiFlag) {
                            try {
                                String storedDigitalUuid = orgParentAccountingDAO.getTelDigitalAddrUuid(ddUuid);

                                if (storedDigitalUuid == null || storedDigitalUuid.isBlank()) {
                                    log.warn("No stored DigitalAddress UUID found for ddUuid={}, skipping update", ddUuid);
                                    break;
                                }

                                log.info("Updating Digital Address for ddUuid={}, onePamUuid={}, digitalAddressUuid={}",
                                        ddUuid, onePamUUID, storedDigitalUuid);

                                UpdateDigitalAddressV5Request updateReq = UpdateDigitalAddressV5Request.builder()
                                        .fullDigitalAddress(wrapper.getAdrDigitalAddrFullTel())
                                        .lastVerificationDate(java.time.OffsetDateTime.now().toString())
                                        .build();


                                digitalAddrService.updateDigitalAddr_LE(
                                        storedDigitalUuid,
                                        "BSN_TEL_NBR",
                                        "TEL_NBR",
                                        "E164",
                                        wrapper.getAdrDigitalAddrFullTel()
                                );

                                orgParentAccountingDAO.updateDigitalAddress_LE_phone(ddUuid, wrapper.getAdrDigitalAddrFullTel(), wrapper.getAdrDigitalAddrFullTel());

                                apiTransactionLogDAO.logApiSuccess(
                                        ddUuid,
                                        wrapper.getFileId(),
                                        COFACE_LE_PARENT_FLOW,
                                        RegkeyEnum.UPDATE_DIGITAL_ADDRESS.endpoint,
                                        RegkeyEnum.UPDATE_DIGITAL_ADDRESS.method,
                                        200
                                );

                                log.info("Digital address update successful for {}", storedDigitalUuid);

                            } catch (Exception ex) {

                                apiTransactionLogDAO.logApiFailure(
                                        ddUuid,
                                        wrapper.getFileId(),
                                        COFACE_LE_PARENT_FLOW,
                                        RegkeyEnum.UPDATE_DIGITAL_ADDRESS.endpoint,
                                        RegkeyEnum.UPDATE_DIGITAL_ADDRESS.method,
                                        "API_ERROR",
                                        ex.getMessage()
                                );
                                log.error("Digital address update failed for ddUuid={}, onePamUUID={}, err={}",
                                        ddUuid, onePamUUID, ex.getMessage());
                                errorLogDAO.logApiError(
                                        RecordType.ORGANISATION_PARENT,
                                        wrapper.getLeExternalIdentifier(),
                                        ddUuid,
                                        null,
                                        "Organisation digital address update failed: " + extractInnerMessage(ex),
                                        RegkeyEnum.UPDATE_DIGITAL_ADDRESS.endpoint,
                                        null,
                                        null,
                                        null,
                                        wrapper.getFileName(),
                                        wrapper.getFileId()
                                );
                            }
                        }
                    }
                } else {
                    log.info("Different digital address usage type={} for ddUuid={}, onePamUUID={}",
                            digitalAddress.getDigitalAddressUsageType(), ddUuid, onePamUUID);
                }
            }

            // ---- NSSO External Identifier Status ----
            for (InvolvedPartyExternalIdentifierResponseV5 involvedPartyExternalIdentifier : involvedPartyExternalIdentifiers) {
                String externalIdentifierStatusType = involvedPartyExternalIdentifier.getInvolvedPartyExternalIdentifierStatusType();
                if (EXT_IDENTIFIER_TYPE_NSSO.equalsIgnoreCase(involvedPartyExternalIdentifier.getInvolvedPartyExternalIdentifierType())) {
                    if (wrapper.getNssoExternalIdentifierStatus() != null
                            && !wrapper.getNssoExternalIdentifierStatus().isEmpty()
                            && externalIdentifierStatusType != null
                            && !Objects.equals(wrapper.getNssoExternalIdentifierStatus(), externalIdentifierStatusType)) {
                        log.info("NssoExternalIdentifierStatus changed ddUuid:{}, onePamUuid:{}, new:{}, old:{}",
                                ddUuid, onePamUUID, wrapper.getNssoExternalIdentifierStatus(), externalIdentifierStatusType);
                        if (!apiFlag) {
                            try {
                                mappingDAO.insertEventTrack(ddUuid, NotificationType.EXTERNAL_IDENTIFIER_NSSO.value(),
                                        EventTransactionType.UPDATE_EXTERNAL_IDENTIFIER_NSSO.getLabel(), NotificationStatus.EXPECTED.name(), null);
                            } catch (Exception ex) {
                                log.info("Organisation update failed while insertEventTrack for UPDATE_EXTERNAL_IDENTIFIER_NSSO , for ddUuid:{}, " +
                                        "error:{}", ddUuid, ex.getMessage());
                            }
                            updateLegalEntityParentDomain.setNssoExternalIdentifierStatus(wrapper.getNssoExternalIdentifierStatus());
                        }
                        // API branch intentionally left blank
                    }
                }
            }

            if (!apiFlag) {
                oilUpdateParentWrappers.add(updateLegalEntityParentDomain);
            }
            try {
                apiTransactionLogDAO.updateNotificationStatusByUuid(ddUuid, wrapper.getFileId());
                log.info("Data_Distributor_Coface_ORG Updated notification status for dd_uuid:{}", ddUuid);
            } catch (Exception e) {
                log.error("Failed to update notification status for dd_uuid:{}, error:{}", ddUuid, e.getMessage(), e);
                errorLogDAO.logDatabaseError(RecordType.ORGANISATION_CHILD, wrapper.getLeExternalIdentifier(), ddUuid, "Failed to update notification status",
                        null, wrapper.getFileName(), null, wrapper.getFileId());
            }
        }
    }
    private String extractInnerMessage(Throwable e) {
        if (e instanceof DataDistributionApiException) {
            String inner = ((DataDistributionApiException) e).getInnerMessage();
            return (inner == null || inner.isBlank()) ? e.getMessage() : inner;
        }
        return e.getMessage();
    }
}
package com.ing.datadist.api.service;

import com.ing.datadist.api.model.IndustryClassificationsResponseV5;
import com.ing.datadist.api.model.UpdateOrganisationIndustryClassificationRequest;
import com.ing.datadist.api.model.UpdateOrganisationIndustryClassificationResponse;
import com.ing.datadist.api.model.industryClassificationResponseV5;
import com.ing.datadist.api.utils.OnePamDateUtil;
import com.ing.datadist.api.utils.RegkeyEnum;
import com.ing.datadist.dao.ApiTransactionLogDAO;
import com.ing.datadist.dao.ErrorLogDAO;
import com.ing.datadist.dao.MappingDAO;
import com.ing.datadist.dao.OrgChildAccountingDAO;
import com.ing.datadist.domain.LegalEntityChildDomain;
import com.ing.datadist.enums.RecordType;
import com.ing.datadist.kafka.util.EventTransactionType;
import com.ing.datadist.kafka.util.NotificationStatus;
import com.ing.datadist.kafka.util.NotificationType;
import lombok.NonNull;
import java.time.LocalDate;
import java.time.OffsetDateTime;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.List;
import java.util.Objects;

import static com.ing.datadist.api.utils.DataDistributionConstants.IDY_CL_NACE_BE;

@Service
@Slf4j
public class UpdateOrganisationChildService {


    private final OrgChildAccountingDAO orgChildAccountingDAO;
    private final IndustryClassificationService industryClassificationService;
    private final ErrorLogDAO errorLogDAO;
    private final ApiTransactionLogDAO apiTransactionLogDAO;
    private final InvolvedPartySearchService searchService;

    @Autowired
    private MappingDAO mappingDAO;

    public UpdateOrganisationChildService(IndustryClassificationService industryClassificationService,
                                          OrgChildAccountingDAO orgChildAccountingDAO,
                                          ErrorLogDAO errorLogDAO,
                                          ApiTransactionLogDAO apiTransactionLogDAO,
                                          InvolvedPartySearchService searchService) {
        this.industryClassificationService = industryClassificationService;
        this.orgChildAccountingDAO = orgChildAccountingDAO;
        this.errorLogDAO = errorLogDAO;
        this.apiTransactionLogDAO = apiTransactionLogDAO;
        this.searchService = searchService;
    }


    public void updateOrganisation(LegalEntityChildDomain wrapper,
                                   IndustryClassificationsResponseV5 response,
                                   @NonNull Boolean apiFlag,
                                   List<LegalEntityChildDomain> legalEntityChildDomains,
                                   String onePamUUID) throws Exception {
        String ddUuid = wrapper.getOrgUUID();

        IndustryClassificationsResponseV5 childIndustryResponse =
                searchService.getOrganisationIndustryClassifications(onePamUUID, wrapper.getFileId());

        List<industryClassificationResponseV5> industryClassifications =
                childIndustryResponse != null ? childIndustryResponse.getIndustryClassifications() : null;

        for (industryClassificationResponseV5 industryClassificationResponseV5 : industryClassifications) {

            if (!IDY_CL_NACE_BE.equalsIgnoreCase(
                    industryClassificationResponseV5.getIndustryClassificationIssuerType())) {
                continue;
            }

            try {
                orgChildAccountingDAO.saveIndustryClassificationOnePamFields(
                        ddUuid,
                        industryClassificationResponseV5
                );
            } catch (Exception ex) {
                errorLogDAO.logDatabaseError(
                        RecordType.ORGANISATION_CHILD,
                        wrapper.getLeExternalIdentifier(),
                        ddUuid,
                        "FAILED TO SAVE ONEPAM INDUSTRY CLASSIFICATION DATA",
                        null,
                        wrapper.getFileName(),
                        null,
                        wrapper.getFileId()
                );
                return;
            }
        }
        if (industryClassifications == null || industryClassifications.isEmpty()) {
            log.info(
                    "No industry classifications returned from OnePAM for ddUuid={}, onePamUUID={}, skipping child update",
                    ddUuid,
                    onePamUUID
            );
            return;
        }

        boolean updateRequiredApi = false;
        boolean updateRequiredOil = false;

        LegalEntityChildDomain oilUpdateWrapper = new LegalEntityChildDomain();
        for (industryClassificationResponseV5 industryClassification : industryClassifications) {

            if (!IDY_CL_NACE_BE.equalsIgnoreCase(
                    industryClassification.getIndustryClassificationIssuerType())) {
                continue;
            }


            LocalDate fileEffDate = wrapper.getIndustryClassEffDate() != null
                    ? LocalDate.parse(wrapper.getIndustryClassEffDate().substring(0, 10))
                    : null;

            LocalDate onePamEffDate = industryClassification.getEffectiveDate() != null
                    ? OffsetDateTime.parse(industryClassification.getEffectiveDate()).toLocalDate()
                    : null;

            if (fileEffDate != null && onePamEffDate != null
                    && !fileEffDate.equals(onePamEffDate)) {

                if (apiFlag) {
                    updateRequiredApi = true;
                } else {
                    updateRequiredOil = true;
                    oilUpdateWrapper.setIndustryClassEffDate(wrapper.getIndustryClassEffDate());
                }
            }

            // End Date
            LocalDate fileEndDate = wrapper.getIndustryClassEndDate() != null
                    ? LocalDate.parse(wrapper.getIndustryClassEndDate().substring(0, 10))
                    : null;

            LocalDate onePamEndDate = industryClassification.getEndDate() != null
                    ? OffsetDateTime.parse(industryClassification.getEndDate()).toLocalDate()
                    : null;

            if (fileEndDate != null && onePamEndDate != null
                    && !fileEndDate.equals(onePamEndDate)) {

                if (apiFlag) {
                    updateRequiredApi = true;
                } else {
                    updateRequiredOil = true;
                    oilUpdateWrapper.setIndustryClassEndDate(wrapper.getIndustryClassEndDate());
                }
            }

            // Rank
            if (wrapper.getIndustryClassRank() != null &&
                    !Objects.equals(wrapper.getIndustryClassRank(), industryClassification.getRank())) {

                if (apiFlag) {
                    updateRequiredApi = true;
                } else {
                    updateRequiredOil = true;
                    oilUpdateWrapper.setIndustryClassRank(wrapper.getIndustryClassRank());
                }
            }if (updateRequiredOil && !apiFlag) {
                try {
                    mappingDAO.insertEventTrack(
                            ddUuid,
                            NotificationType.INDUSTRY_CLASSIFICATION.value(),
                            EventTransactionType.UPDATE_ORG_INDUSTRY_CLASSIFICATION.getLabel(),
                            NotificationStatus.EXPECTED.name(),
                            null
                    );
                } catch (Exception ex) {
                    log.warn(
                            "Failed to insert OIL event for INDUSTRY_CLASSIFICATION, ddUuid={}, error={}",
                            ddUuid,
                            ex.getMessage()
                    );
                }

                legalEntityChildDomains.add(oilUpdateWrapper);
            }


            log.info("FINAL industry classification update decision for ddUuid={} → updateRequired={}",
                    ddUuid, updateRequiredApi);

            if (updateRequiredApi && apiFlag) {

                UpdateOrganisationIndustryClassificationRequest updateReq =
                        UpdateOrganisationIndustryClassificationRequest.builder()
                                .rank(wrapper.getIndustryClassRank())
                                .effectiveDate(OnePamDateUtil.toOnePamDate(
                                        wrapper.getIndustryClassEffDate()))
                                .endDate(OnePamDateUtil.toOnePamDate(
                                        wrapper.getIndustryClassEndDate()))
                                .build();

                UpdateOrganisationIndustryClassificationResponse resp =
                        industryClassificationService.updateIndustryClassification(
                                onePamUUID,
                                IDY_CL_NACE_BE,
                                wrapper.getIndustryClassCode(),
                                updateReq,
                                wrapper.getFileId()
                        );

                log.info("Industry classification UPDATE successful for ddUuid={}", ddUuid);
            }
        }
    }

}
