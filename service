    public void processOrganisation(String ddUuid, LegalEntityParentDomain wrapper, List<LegalEntityChildDomain> childWrappers) {

        CreateInvolvedPartyResponseV5 response = null;
        try {
            response = createOrganisation(ddUuid, wrapper);

            apiTransactionLogDAO.logApiSuccess(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.endpoint,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.method,
                    200
            );

            orgParentAccountingDAO.insertFullOrganisation(response, wrapper.getFileId(),wrapper);
        } catch (Exception e) {


            apiTransactionLogDAO.logApiFailure(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.endpoint,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.method,
                    "API_ERROR",
                    extractInnerMessage(e)
            );
            errorLogDAO.logApiError(
                    RecordType.ORGANISATION_PARENT,
                    wrapper.getLeExternalIdentifier(),
                    ddUuid,
                    null,
                    "Create organisation failed: " + extractInnerMessage(e),
                    RegkeyEnum.CREATE_INVOLVED_PARTY.endpoint,
                    null,
                    null,
                    null,
                    wrapper.getFileName(),
                    wrapper.getFileId()
            );
            log.error("Failed to create organisation for ddUuid: {}", ddUuid, e);
            try {
                apiTransactionLogDAO.updateNotificationStatusByUuid(ddUuid, wrapper.getFileId());
                log.info("Data_Distributor_Coface_ORG Updated notification status for dd_uuid:{} after organisation creation failure", ddUuid);
            } catch (Exception statusEx) {
                log.error("Failed to update notification status for dd_uuid:{}, error:{}", ddUuid, statusEx.getMessage());
                errorLogDAO.logDatabaseError(RecordType.ORGANISATION_PARENT, wrapper.getLeExternalIdentifier(), ddUuid, "Failed to update notification status for dd_uuid" + extractInnerMessage(e), null, wrapper.getFileName(), null, wrapper.getFileId() );
            }
            return;
        }

        String onePamUUID = response.getOrganisation().getInvolvedPartyIdentifier();
        if (onePamUUID != null && !onePamUUID.isBlank()) {
            updateExternalIdentifier(ddUuid, onePamUUID, wrapper);
        } else {
            log.warn("No onePamUUID found; skipping external ID update for ddUuid {}", ddUuid);
        }

        CreatePostalAddressRequest postalRequest = new CreatePostalAddressRequest();
        postalRequest.setHouseNumber(wrapper.getAdrPostalAddressHouseNum());
        postalRequest.setPostalCode(wrapper.getAdrPostalAddressPostalCode());
        postalRequest.setCountryCode(wrapper.getAdrPostalAddressCountryCode());
        postalRequest.setHouseNumberAddition(wrapper.getAdrPostalAddressHouseNumAdd());
        postalRequest.setCityName(wrapper.getAdrPostalAddressCityName());
        postalRequest.setStreetName(wrapper.getAdrPostalAddressStreetName());
        postalRequest.setUnstructuredAddressLine(wrapper.getAdrUnstructuredAddress());
        postalRequest.setDataSource(DATA_SOURCE);

        try {
            log.info("Data_Distributor_Coface_ORG Calling PostalAddress-API for dd_uuid:{}, onePamUuid:{}", ddUuid, onePamUUID);
            PostalAddressResponse addr = addressService.createPostalAddress(onePamUUID, postalRequest, wrapper.getFileId());

            if (addr != null) {
                apiTransactionLogDAO.logApiSuccess(
                        ddUuid,
                        wrapper.getFileId(),
                        COFACE_LE_PARENT_FLOW,
                        RegkeyEnum.CREATE_POSTAL_ADDRESS.resolveEndpoint(onePamUUID),
                        RegkeyEnum.CREATE_POSTAL_ADDRESS.method,
                        200
                );

                orgParentAccountingDAO.insertPostalAddrWithWrapperLE(ddUuid, postalRequest.getStreetName(), postalRequest.getHouseNumber(),
                        postalRequest.getHouseNumberAddition(), postalRequest.getPostalCode(), postalRequest.getCityName(), postalRequest.getCountryCode(), postalRequest.getUnstructuredAddressLine(), wrapper.getFileId());
                log.info("Data_Distributor_Coface_ORG PostalAddress-API call success for dd_uuid:{}, onePamUuid:{}", ddUuid, onePamUUID);
            } else {
                log.warn("Postal address response was null for UUID={}", ddUuid);
            }
        } catch (Exception e) {
            apiTransactionLogDAO.logApiFailure(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_POSTAL_ADDRESS.resolveEndpoint(onePamUUID),
                    RegkeyEnum.CREATE_POSTAL_ADDRESS.method,
                    "API_ERROR",
                    extractInnerMessage(e)
            );
            errorLogDAO.logApiError(
                    RecordType.ORGANISATION_PARENT,
                    wrapper.getLeExternalIdentifier(),
                    ddUuid,
                    null,
                    "Postal address create failed: " + extractInnerMessage(e),
                    RegkeyEnum.CREATE_POSTAL_ADDRESS.endpoint,
                    null,
                    null,
                    null,
                    wrapper.getFileName(),
                    wrapper.getFileId()
            );
            log.error("Postal address create failed for UUID={} : {}", ddUuid, extractInnerMessage(e), e);
        }

        try {
            String tel = wrapper.getAdrDigitalAddrFullTel();

            log.info("Data_Distributor_Coface_ORG Checking digital addresses for dd_uuid:{} tel='{}' ",
                    ddUuid, tel);

            if (tel != null && !tel.isBlank()) {
                log.info("Data_Distributor_Coface_ORG Creating EMAIL digital address for onePamUuid:{} value:{}",
                        onePamUUID, tel);

                CreateDigitalAddressV5Request requestForPhone =
                        digitalAddrService.buildCreateRequestForPhone(onePamUUID, tel);


                digitalAddrService.createDigitalAddr_LE(ddUuid, onePamUUID, requestForPhone);
                orgParentAccountingDAO.updateDigitalAddress_LE_phone(ddUuid, wrapper.getAdrDigitalAddrFullTel(),wrapper.getFileId());
                apiTransactionLogDAO.logApiSuccess(
                        ddUuid,
                        wrapper.getFileId(),
                        COFACE_LE_PARENT_FLOW,
                        RegkeyEnum.CREATE_DIGITAL_ADDRESS.endpoint,
                        RegkeyEnum.CREATE_DIGITAL_ADDRESS.method,
                        200
                );

                log.info("TELEPHONE digital address created successfully for {}", onePamUUID);
            }

            if ((tel == null || tel.isBlank())){
                log.info("Data_Distributor_Coface_ORG No digital address (phone) provided for onePamUuid:{}, skipping.",
                        onePamUUID);
            }

        } catch (Exception e) {
            log.error("Data_Distributor_Coface_ORG Digital address creation failed for dd_uuid={} : {}", ddUuid, extractInnerMessage(e), e);

            apiTransactionLogDAO.logApiFailure(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_DIGITAL_ADDRESS.endpoint,
                    RegkeyEnum.CREATE_DIGITAL_ADDRESS.method,
                    "API_ERROR",
                    extractInnerMessage(e)
            );
            errorLogDAO.logApiError(
                    RecordType.ORGANISATION_PARENT,
                    wrapper.getLeExternalIdentifier(),
                    ddUuid,
                    null,
                    "CREATE_DIGITAL_ADDRESS failed: " + extractInnerMessage(e),
                    RegkeyEnum.CREATE_DIGITAL_ADDRESS.endpoint,
                    null,
                    null,
                    null,
                    wrapper.getFileName(),
                    wrapper.getFileId()
            );
        }
        try {
            String typeFromFile = ASSESSMENT_TYPE;
            String resultTypeFromFile = "I";
            String effectiveDateFromFile = wrapper.getOrgDateOfFoundation();
            String dataSourceFromFile = DATA_SOURCE;

            CreateAssessmentRequest assessmentRequest =
                    organisationAssessmentService.buildAssessmentRequest(
                            typeFromFile,
                            resultTypeFromFile,
                            dataSourceFromFile,
                            effectiveDateFromFile
                    );

            log.info("Calling createAssessment for dd_uuid:{}, onePamUuid:{}", ddUuid, onePamUUID);
            CreateAssessmentResponse asmtResp =
                    organisationAssessmentService.createAssessment(onePamUUID, assessmentRequest, wrapper.getFileId());
            apiTransactionLogDAO.logApiSuccess(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_ASSESSMENT.resolveEndpoint(onePamUUID),
                    RegkeyEnum.CREATE_ASSESSMENT.method,
                    200
            );

            log.info("Assessment created for dd_uuid:{}, onePamUuid:{}, response: {}",
                    ddUuid, onePamUUID, asmtResp);

            orgParentAccountingDAO.insertAssessment(ddUuid, asmtResp.getAssessment().getResultType());

        } catch (Exception e) {
            apiTransactionLogDAO.logApiFailure(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_ASSESSMENT.resolveEndpoint(onePamUUID),
                    RegkeyEnum.CREATE_ASSESSMENT.method,
                    "API_ERROR",
                    extractInnerMessage(e)
            );
            errorLogDAO.logApiError(
                    RecordType.ORGANISATION_PARENT,
                    wrapper.getLeExternalIdentifier(),
                    ddUuid,
                    null,
                    "CREATE_ASSESSMENT failed: " + extractInnerMessage(e),
                    RegkeyEnum.CREATE_ASSESSMENT.endpoint,
                    null,
                    null,
                    null,
                    wrapper.getFileName(),
                    wrapper.getFileId()
            );
            log.error("Assessment creation failed for dd_uuid:{}, onePamUuid:{}; cause: {}",
                    ddUuid, onePamUUID, extractInnerMessage(e), e);
        }

        try {
            if (childWrappers != null && !childWrappers.isEmpty()) {

                for (LegalEntityChildDomain child : childWrappers) {
                    String code = child.getIndustryClassCode();
                    if (code == null || code.isBlank()) {
                        log.info("Industry classification not available in child row for ddUuid:{}; skipping", ddUuid);
                        continue;
                    }


                    CreateOrganisationIndustryClassificationRequest industryClassificationRequest =
                            CreateOrganisationIndustryClassificationRequest.builder()
                                    .industryClassificationIssuerType(LE_INDUSTRY_CLASSIFICATION_ISSUER_TYPE)
                                    .industryClassificationCode(child.getIndustryClassCode())
                                    .rank(child.getIndustryClassRank())
                                    .effectiveDate(OnePamDateUtil.toOnePamDate(child.getIndustryClassEffDate()))
                                    .endDate(OnePamDateUtil.toOnePamDate(child.getIndustryClassEndDate()))
                                    .build();

                    log.info("Calling IndustryClassificationService.addIndustryClassification for dd_uuid:{}, onePamUuid:{}, payload:{}",
                            ddUuid, onePamUUID, industryClassificationRequest);

                    try {
                        CreateOrganisationIndustryClassificationResponse icResp =
                                industryClassificationService.addIndustryClassification(onePamUUID, industryClassificationRequest, wrapper.getFileId());

                        apiTransactionLogDAO.logApiSuccess(
                                ddUuid,
                                wrapper.getFileId(),
                                COFACE_LE_PARENT_FLOW,
                                RegkeyEnum.CREATE_INDUSTRY_CLASSIFICATION.resolveEndpoint(onePamUUID),
                                RegkeyEnum.CREATE_INDUSTRY_CLASSIFICATION.method,
                                200
                        );

                        log.info("Industry classification created for dd_uuid:{}, onePamUuid:{}, response:{}",
                                ddUuid, onePamUUID, icResp);

                        orgChildAccountingDAO.insertIndustryClassification(
                                ddUuid,
                                industryClassificationRequest.getIndustryClassificationCode(),
                                String.valueOf(industryClassificationRequest.getRank()),
                                industryClassificationRequest.getEffectiveDate(),
                                industryClassificationRequest.getEndDate(),
                                wrapper.getLeExternalIdentifier(),
                                wrapper.getFileId()
                        );
                    } catch (Exception icException) {
                        apiTransactionLogDAO.logApiFailure(
                                ddUuid,
                                wrapper.getFileId(),
                                COFACE_LE_PARENT_FLOW,
                                RegkeyEnum.CREATE_INDUSTRY_CLASSIFICATION.resolveEndpoint(onePamUUID),
                                RegkeyEnum.CREATE_INDUSTRY_CLASSIFICATION.method,
                                "API_ERROR",
                                icException.getMessage()
                        );
                        errorLogDAO.logApiError(
                                RecordType.ORGANISATION_PARENT,
                                wrapper.getLeExternalIdentifier(),
                                ddUuid,
                                null,
                                "CREATE_INDUSTRY_CLASSIFICATION failed: " + extractInnerMessage(icException),
                                RegkeyEnum.CREATE_INDUSTRY_CLASSIFICATION.endpoint,
                                null,
                                null,
                                null,
                                wrapper.getFileName(),
                                wrapper.getFileId()
                        );
                        log.error("Industry classification creation failed for dd_uuid:{}, onePamUuid:{}; cause:{}",
                                ddUuid, onePamUUID, icException.getMessage(), icException);
                    }

                }

            } else {
                log.info("No child rows provided for industry classification creation for ddUuid {}", ddUuid);
            }

        } catch (Exception e) {
            log.error("Industry classification creation failed for dd_uuid:{}, onePamUuid:{}; cause:{}",
                    ddUuid, onePamUUID, extractInnerMessage(e), e);

        }
        try {
            apiTransactionLogDAO.updateNotificationStatusByUuid(ddUuid, wrapper.getFileId());
            log.info("Data_Distributor_Coface_ORG Updated notification status for dd_uuid:{}", ddUuid);
        } catch (Exception e) {
            log.error("Failed to update notification status for dd_uuid:{}, error:{}", ddUuid, extractInnerMessage(e));
            errorLogDAO.logDatabaseError(RecordType.ORGANISATION_PARENT, wrapper.getLeExternalIdentifier(), ddUuid, "Failed to update notification status for dd_uuid" + extractInnerMessage(e), null, wrapper.getFileName(), null, wrapper.getFileId() );
        }
    }

    public CreateInvolvedPartyResponseV5 createOrganisation(String ddUuid, LegalEntityParentDomain wrapper) {
        log.info("Data_Distributor_Coface_ORG Creating organisation with Primary Name: {}, Other Name: {}",
                wrapper.getOrgName(), wrapper.getOrgOtherName());
        log.info("Data_Distributor_Coface_ORG Name Types - Primary: {}, Other: {}",
                ORGANISATION_NAME_TYPE, ORGANISATION_OTHER_NAME_TYPE);
        String effDate = OnePamDateUtil.toOnePamDate(null);

        List<CreateOrganisationNameRequest> organisationNamesList = new ArrayList<>();

        if (wrapper.getOrgName() != null && !wrapper.getOrgName().isBlank()) {
            organisationNamesList.add(
                    CreateOrganisationNameRequest.builder()
                            .organisationNameType(ORGANISATION_NAME_TYPE)
                            .organisationName(wrapper.getOrgName())
                            .dataSource(DATA_SOURCE)
                            .build()
            );
        }

        /* Add other organisation name if present */
        if (wrapper.getOrgOtherName() != null && !wrapper.getOrgOtherName().isBlank()) {
            organisationNamesList.add(
                    CreateOrganisationNameRequest.builder()
                            .organisationNameType(ORGANISATION_OTHER_NAME_TYPE)
                            .organisationName(wrapper.getOrgOtherName())
                            .dataSource(DATA_SOURCE)
                            .build()
            );
        }

        log.info("Data_Distributor_Coface_ORG Total organisation names to create: {}", organisationNamesList.size());

        CreateOrganisationRequest.CreateOrganisationRequestBuilder orgBuilder = CreateOrganisationRequest.builder()
                .dataSource(DATA_SOURCE)
                .logicalDataDomain(LOGICAL_DATA_DOMAIN)
                .countryOfResidence(wrapper.getAdrPostalAddressCountryCode())
                .preferredLanguage(wrapper.getLEPreferredLanguage())
                .channelOfEntry(CHANNEL_OF_ENTRY)
                .dateOfFoundation(wrapper.getOrgDateOfFoundation())
                .effectiveDate(effDate)
                .financialLegalStatusType(wrapper.getLELegalStatus()) //legal status
                .organisationLifeCycleStatusType(wrapper.getOrgStatus()) //org status
                .legalForm(wrapper.getOrgLegalForm())
                .businessClosedDownDate(wrapper.getOrgBusinessClosedownDate())
                .involvedPartyInternalIdentifiers(Collections.singletonList(
                        CreateInternalIdentifierRequest.builder()
                                .involvedPartyInternalIdentifierType(DD_IDENTIFIER_TYPE)
                                .involvedPartyInternalIdentifierValue(ddUuid)
                                .build()
                ))
                .organisationNames(organisationNamesList);

        CreateInvolvedPartyRequestV5 request = CreateInvolvedPartyRequestV5.builder().organisation(orgBuilder.build()).build();
        try {
            CreateInvolvedPartyResponseV5 resp =
                    involvedPartyOnePamRepository.createInvolvedParty(request).get();

            apiTransactionLogDAO.logApiSuccess(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.endpoint,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.method,
                    200
            );

            return resp;

        } catch (Exception e) {

            apiTransactionLogDAO.logApiFailure(
                    ddUuid,
                    wrapper.getFileId(),
                    COFACE_LE_PARENT_FLOW,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.endpoint,
                    RegkeyEnum.CREATE_INVOLVED_PARTY.method,
                    "API_ERROR",
                    extractInnerMessage(e)
            );

            log.error("Create failed for ddUuid {}: {}", ddUuid, extractInnerMessage(e), e);
            throw new RuntimeException("Create organisation interrupted", e);
        }
    }

    public void updateExternalIdentifier(String ddUuid, String onePamUUID, LegalEntityParentDomain wrapper) {
        try {
            String externalIdentifier = wrapper.getLeExternalIdentifier();
            UpdateExternalIdentifierInvolvedPartyRequest updateRequest = buildUpdateRequest(ddUuid, wrapper, externalIdentifier, false);

            try {
                Response resp = involvedPartyOnePamRepository.updateExternalIdentifier(onePamUUID, updateRequest).get();

                // Log successful KBO external identifier API transaction
                apiTransactionLogDAO.logApiSuccess(
                        ddUuid,
                        wrapper.getFileId(),
                        COFACE_LE_PARENT_FLOW,
                        RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.resolveEndpoint(onePamUUID),
                        RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.method,
                        200
                );

                orgParentAccountingDAO.updateExternalIdentifierLE(ddUuid, externalIdentifier, wrapper.getOrgDateOfFoundation(),wrapper.getOrgBusinessClosedownDate(), wrapper.getFileId());
            } catch (Exception kboException) {
                // Log failed KBO external identifier API transaction
                apiTransactionLogDAO.logApiFailure(
                        ddUuid,
                        wrapper.getFileId(),
                        "COFACE_LE_PARENT",
                        RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.resolveEndpoint(onePamUUID),
                        RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.method,
                        "API_ERROR",
                        extractInnerMessage(kboException)
                );
                errorLogDAO.logApiError(
                        RecordType.ORGANISATION_PARENT,
                        wrapper.getLeExternalIdentifier(),
                        ddUuid,
                        null,
                        "UPDATE EXTERNAL IDENTIFIER: " + extractInnerMessage(kboException),
                        RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.endpoint,
                        null,
                        null,
                        null,
                        wrapper.getFileName(),
                        wrapper.getFileId()
                );
                throw kboException;
            }

            String nssoExternalIdentifier = wrapper.getNssoExternalIdentifier();
            String nssoStatus = wrapper.getNssoExternalIdentifierStatus();

            if (nssoExternalIdentifier != null && !nssoExternalIdentifier.isBlank()) {
                UpdateExternalIdentifierInvolvedPartyRequest nssoUpdateRequest = buildUpdateRequest(ddUuid, wrapper, nssoExternalIdentifier, true);

                try {
                    Response respNsso = involvedPartyOnePamRepository.updateExternalIdentifier(onePamUUID, nssoUpdateRequest).get();

                    // Log successful NSSO external identifier API transaction
                    apiTransactionLogDAO.logApiSuccess(
                            ddUuid,
                            wrapper.getFileId(),
                            "COFACE_LE_PARENT",
                            RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.resolveEndpoint(onePamUUID),
                            RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.method,
                            200
                    );

                    orgParentAccountingDAO.updateExternalIdentifierNSSO(ddUuid, wrapper.getNssoExternalIdentifierStatus(), wrapper.getNssoExternalIdentifier(), wrapper.getFileId());
                } catch (Exception nssoException) {
                    // Log failed NSSO external identifier API transaction
                    apiTransactionLogDAO.logApiFailure(
                            ddUuid,
                            wrapper.getFileId(),
                            COFACE_LE_PARENT_FLOW,
                            RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.resolveEndpoint(onePamUUID),
                            RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.method,
                            "API_ERROR",
                            extractInnerMessage(nssoException)
                    );
                    errorLogDAO.logApiError(
                            RecordType.ORGANISATION_PARENT,
                            wrapper.getLeExternalIdentifier(),
                            ddUuid,
                            null,
                            "UPDATE_EXTERNAL_IDENTIFIER FAILED: " + extractInnerMessage(nssoException),
                            RegkeyEnum.UPDATE_EXTERNAL_IDENTIFIER.endpoint,
                            null,
                            null,
                            null,
                            wrapper.getFileName(),
                            wrapper.getFileId()
                    );
                    log.error("NSSO external identifier update failed for ddUuid: {}", ddUuid, nssoException);
                }
            }
        } catch (Exception e) {
            log.error("Update external identifier failed for ddUuid {}: {}", ddUuid, extractInnerMessage(e), e);
        }
    }

    private UpdateExternalIdentifierInvolvedPartyRequest buildUpdateRequest(String uuid, LegalEntityParentDomain wrapper, String externalIdentifierValue, boolean isNssoIdentifier) {
        String finalExternalIdentifier = (externalIdentifierValue != null && !externalIdentifierValue.isBlank())
                ? externalIdentifierValue
                : isNssoIdentifier ? wrapper.getNssoExternalIdentifier() : wrapper.getLeExternalIdentifier();

        String type = isNssoIdentifier ? EXTERNAL_ID_TYPE_NSSO : EXTERNAL_ID_TYPE_KBO;
        UpdateExternalIdentifierInvolvedPartyRequest.UpdateExternalIdentifierInvolvedPartyRequestBuilder builder =
                UpdateExternalIdentifierInvolvedPartyRequest.builder()
                        .dataSource(DataDistributionConstants.DATA_SOURCE)
                        .involvedPartyExternalIdentifierType(type)
                        .effectiveDate(OnePamDateUtil.toOnePamDate(wrapper.getOrgDateOfFoundation()))
                        .involvedPartyExternalIdentifierValue(finalExternalIdentifier);
//                        .involvedPartyExternalIdentifierStatusType("ACTV");
        return builder.build();
    }

    public GetInvolvedPartyResponseV6 updateOrganisation(String onePamUUID, LegalEntityParentDomain wrapper) {
        try {
            UpdateOrganisationRequest.Organisation org = UpdateOrganisationRequest.Organisation.builder()
                    .dataSource(DATA_SOURCE)
                    .countryOfResidence(wrapper.getAdrPostalAddressCountryCode())
                    .preferredLanguage(wrapper.getLEPreferredLanguage())
                    .financialLegalStatusType(wrapper.getLELegalStatus())
                    .channelOfEntry(CHANNEL_OF_ENTRY)
                    .effectiveDate(OnePamDateUtil.toOnePamDate(wrapper.getOrgDateOfFoundation()))
                    .legalForm(wrapper.getOrgLegalForm())
                    .dateOfFoundation(wrapper.getOrgDateOfFoundation())
                    .businessClosedDownDate(wrapper.getOrgBusinessClosedownDate())
                    .organisationLifeCycleStatusType(wrapper.getOrgStatus())
                    .build();
            UpdateOrganisationRequest request = UpdateOrganisationRequest.builder().organisation(org).build();
            return organisationOnePamRepository.updateOrganisation(onePamUUID, request).get();
        } catch (Exception e) {
            log.error("updateOrganisation failed for onePamUUID {}: {}", onePamUUID, extractInnerMessage(e), e);
            throw new RuntimeException("updateOrganisation failed", e);
        }
    }

    private String extractInnerMessage(Throwable e) {
        if (e instanceof DataDistributionApiException) {
            String inner = ((DataDistributionApiException) e).getInnerMessage();
            return (inner == null || inner.isBlank()) ? e.getMessage() : inner;
        }
        return e.getMessage();
    }


