@Slf4j
public class LegalEntityChildDAO {

    private final JdbcTemplate jdbcTemplate;

    public LegalEntityChildDAO(JdbcTemplate jdbcTemplate) {
        this.jdbcTemplate = jdbcTemplate;
    }

    public List<LegalEntityChildDomain> fetchRecordsByFileId(String fileId, int limit) {
        log.info("Data_Distributor_Coface_LE: Fetching child records for fileId={}, limit={}", fileId, limit);
        List<LegalEntityChildDomain> records = jdbcTemplate.query(
                LegalEntityQueries.FETCH_CHILD_RECORDS_BY_FILE_ID,
                legalEntityChildDomainMapper(),
                fileId,
                limit);
        log.info("Data_Distributor_Coface_LE: Fetched {} child records for fileId={}", records.size(), fileId);
        return records;
    }

    public List<LegalEntityChildDomain> fetchRecordsByDdUuid(String ddUuid) {
        log.info("Data_Distributor_Coface_LE: Fetching child records for ddUuid={}", ddUuid);
        List<LegalEntityChildDomain> records = jdbcTemplate.query(
                LegalEntityQueries.FETCH_CHILD_RECORDS_BY_DD_UUID,
                legalEntityChildDomainMapper(),
                ddUuid);
        log.info("Data_Distributor_Coface_LE: Fetched {} child records for ddUuid={}", records.size(), ddUuid);
        return records;
    }

    private RowMapper<LegalEntityChildDomain> legalEntityChildDomainMapper() {
        return (rs, rowNum) -> {
            LegalEntityChildDomain domain = new LegalEntityChildDomain();
            domain.setOrgUUID(rs.getString(DD_UUID));
            domain.setIndustryClassCode(rs.getString(INDUSTRY_CLASS_CODE));
            
            String rankStr = rs.getString(INDUSTRY_CLASS_CODE_RANK);
            if (rankStr != null && !rankStr.isEmpty()) {
                try {
                    domain.setIndustryClassRank(Integer.parseInt(rankStr));
                } catch (NumberFormatException e) {
                    log.warn("Invalid industry class rank value: {}", rankStr);
                    domain.setIndustryClassRank(null);
                }
            }
            
            domain.setIndustryClassEffDate(rs.getString(INDUSTRY_CLASS_EFF_DATE));
            domain.setIndustryClassEndDate(rs.getString(INDUSTRY_CLASS_END_DATE));
            domain.setFileId(rs.getString(FILE_ID));
            return domain;
        };
    }
}

