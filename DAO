                """;
        jdbcTemplate.update(sql, UUID, finalStatus, fileId);
    }


    public boolean eventTrackRecordExists(String ddUuid, String notificationType, String transactionType, String status) {
        log.debug("Checking if event track record exists for ddUuid={}, notificationType={}, transactionType={}, status={}",
                ddUuid, notificationType, transactionType, status);

        String sql = "SELECT COUNT(*) FROM DD_EVENT_TRACK_TBL WHERE DD_UUID = ? AND NOTIFICATION_TYPE = ? AND TRANSACTION_TYPE=? AND STATUS IN ('RECEIVED', 'EXPECTED')";
        Integer count = jdbcTemplate.queryForObject(sql, Integer.class, ddUuid, notificationType, transactionType);

        log.debug("Event track record count={} for ddUuid={}, notificationType={}, transactionType={}",
                count, ddUuid, notificationType, transactionType);

        if (count == null || count == 0) {
            log.info("No event track record found for ddUuid={}, notificationType={}, transactionType={}",
                    ddUuid, notificationType, transactionType);
            return false;
        } else if (count == 1) {
            log.info("Event track record exists for ddUuid={}, notificationType={}, transactionType={}",
                    ddUuid, notificationType, transactionType);
            return true;
        } else {
            log.error("Multiple event track records found (count={}) for ddUuid={}, notificationType={}, transactionType={}, status={}",
                    count, ddUuid, notificationType, transactionType, status);
            throw new IllegalStateException("Multiple records found for DD_UUID: " + ddUuid +
                    ", NotificationType: " + notificationType + ", Status: " + status);
        }
    }

    public void updateBulkStatus(List<String> uuids, String finalStatus, String fileId) {
        String sql = "INSERT INTO DD_NOTIFICATION_STATUS (DD_UUID, STATUS, FILE_ID) VALUES (?, ?, ?)";
        jdbcTemplate.batchUpdate(sql, uuids, uuids.size(), (ps, uuid) -> {
            ps.setString(1, uuid);
            ps.setString(2, finalStatus);
            ps.setString(3, fileId);
        });
    }

