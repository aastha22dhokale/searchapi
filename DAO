    public List<String> findPendingNotifications(String uuid) {
        String sql = """
                    SELECT e.notification_type
                    FROM DD_EVENT_TRACK_TBL e
                    WHERE e.DD_UUID = ?
                      AND e.status = ?
                
                """;
        return jdbcTemplate.query(sql, (rs, i) -> rs.getString(1), uuid, NotificationStatus.EXPECTED.name());
    }

    public List<String> findPendingNotifications() {
        String sql = """
                    SELECT   e.notification_type
                       FROM DD_EVENT_TRACK_TBL e
                       WHERE e.status = ?
                       ORDER BY e.DD_UUID
                """;
        return jdbcTemplate.query(sql, (rs, i) -> rs.getString(1), NotificationStatus.EXPECTED.name());
    }

    public boolean areAllNotificationsValidated(String ddUuid) {
        String sql = """
                    SELECT COUNT(*)
                    FROM DD_EVENT_TRACK_TBL
                    WHERE DD_UUID = ?
                      AND STATUS <> ?
                """;
        Integer count = jdbcTemplate.queryForObject(sql, Integer.class, ddUuid, NotificationStatus.SYNCHRONIZED.name());
        return count != null && count == 0;
    }

    public List<String> findUuidsMissingValidatedStatusAndNotInNotificationStatus() {
        String sql = """
                    SELECT DISTINCT e.DD_UUID
                    FROM DD_EVENT_TRACK_TBL e
                    WHERE e.STATUS <> ?
                      AND NOT EXISTS (
                          SELECT 1 FROM DD_NOTIFICATION_STATUS n
                          WHERE n.DD_UUID = e.DD_UUID
                      )
                """;
        return jdbcTemplate.query(sql, (rs, i) -> rs.getString(1), NotificationStatus.SYNCHRONIZED.name());
    }

    public List<String> findUuidsAllNotificationsValidatedAndNotInNotificationStatus() {
        String sql = """
                    SELECT DISTINCT e.DD_UUID
                    FROM DD_EVENT_TRACK_TBL e
                    WHERE NOT EXISTS (
                        SELECT 1 FROM DD_EVENT_TRACK_TBL et
                        WHERE et.DD_UUID = e.DD_UUID
                          AND et.STATUS <> ?
                    )
                    AND NOT EXISTS (
                        SELECT 1 FROM DD_NOTIFICATION_STATUS n
                        WHERE n.DD_UUID = e.DD_UUID
                    )
                """;
        return jdbcTemplate.query(sql, (rs, i) -> rs.getString(1), NotificationStatus.SYNCHRONIZED.name());
    }

