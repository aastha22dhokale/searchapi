    public void batchInsertMappingRecords(List<MappingTableRecord> records) {
        if (records.isEmpty()) {
            log.info("batchInsertMappingRecords: No records to insert");
            return;
        }

        log.info("batchInsertMappingRecords: Starting batch insert for {} records", records.size());

        String sql = "INSERT INTO DD_MAP_TBL (" +
                MappingDbFields.DD_UUID + ", " +
                MappingDbFields.INCAPABLE_KEY + ", " +
                MappingDbFields.TYP_OF_ENTY + ") " +
                "VALUES (?, ?, ?)";

        try {
            jdbcTemplate.batchUpdate(sql, new BatchPreparedStatementSetter() {
                @Override
                public void setValues(@NonNull PreparedStatement ps, int i) throws SQLException {
                    MappingTableRecord record = records.get(i);

                    ps.setString(1, record.getDdUuid());
                    ps.setString(2, record.getCompositeKey());
                    ps.setString(3, record.getTypeOfEntity());
                }

                @Override
                public int getBatchSize() {
                    return records.size();
                }
            });

            log.info("batchInsertMappingRecords: Successfully inserted {} records", records.size());
        } catch (Exception e) {
            log.error("batchInsertMappingRecords: Error during batch insert", e);
            throw e;
        }
    }


    public String findUuidByCompositeKey(String compositeKey) {
        log.debug("findUuidByCompositeKey: compositeKey={}", compositeKey);

        String sql = "SELECT " + MappingDbFields.DD_UUID +
                " FROM DD_MAP_TBL WHERE " +
                MappingDbFields.INCAPABLE_KEY + " = ? AND " +
                MappingDbFields.TYP_OF_ENTY + " = ?";

        try {
            String uuid = jdbcTemplate.queryForObject(sql, new Object[]{compositeKey, FlowType.INCAPABLE.getLabel()}, String.class);
            log.debug("findUuidByCompositeKey: Found UUID={} for composite key", uuid);
            return uuid;
        } catch (org.springframework.dao.EmptyResultDataAccessException e) {
            log.debug("findUuidByCompositeKey: No record found for composite key");
            return null;
        }
    }


    public MappingTableRecord findIncapablesByCompositeKey(String compositeKey) {
        log.debug("findIncapablesByCompositeKey: compositeKey={}", compositeKey);

        String sql = "SELECT " + MappingDbFields.DD_UUID + ", " +
                MappingDbFields.INCAPABLE_KEY + ", " +
                MappingDbFields.TYP_OF_ENTY +
                " FROM DD_MAP_TBL WHERE " +
                MappingDbFields.INCAPABLE_KEY + " = ? AND " +
                MappingDbFields.TYP_OF_ENTY + " = ?";

        try {
            return jdbcTemplate.queryForObject(sql,
                    new Object[]{compositeKey, FlowType.INCAPABLE.getLabel()},
                    (rs, rowNum) -> MappingTableRecord.builder()
                            .ddUuid(rs.getString(MappingDbFields.DD_UUID))
                            .compositeKey(rs.getString(MappingDbFields.INCAPABLE_KEY))
                            .typeOfEntity(rs.getString(MappingDbFields.TYP_OF_ENTY))
                            .build());
        } catch (org.springframework.dao.EmptyResultDataAccessException e) {
            log.debug("findIncapablesByCompositeKey: No record found for composite key");
            return null;
        }
    }


    public Map<String, String> fetchAllIncapableFlowUuidMappings() {
        log.debug("fetchAllIncapableFlowUuidMappings: Fetching all incapable flow mappings");

        String sql = "SELECT " + MappingDbFields.INCAPABLE_KEY + ", " +
                MappingDbFields.DD_UUID +
                " FROM DD_MAP_TBL WHERE " +
                MappingDbFields.TYP_OF_ENTY + " = ?";

        return jdbcTemplate.query(sql, rs -> {
            Map<String, String> result = new HashMap<>();
            while (rs.next()) {
                String compositeKey = rs.getString(MappingDbFields.INCAPABLE_KEY);
                String uuid = rs.getString(MappingDbFields.DD_UUID);
                result.put(compositeKey, uuid);
            }
            log.debug("fetchAllIncapableFlowUuidMappings: Retrieved {} mappings", result.size());
            return result;
        }, FlowType.INCAPABLE.getLabel());
    }
}
