 */
@Repository
@Slf4j
public class IncapablesDAO {

    /**
     * SQL for inserting incapable records via Spring Batch bean-mapped writer.
     * Uses named parameters matching IncapableRelationship domain object properties.
     */
    public static final String INCAPABLES_TABLE_INSERT_SQL = "INSERT INTO DD_INCAPABLES_TBL (" +
            DD_UUID + ", " + INCP_GENDER + ", " + INCP_LASTNAME + ", " + INCP_FIRSTNAME + ", " + INCP_STREETNAME + ", " +
            INCP_HOUSENUMBER + ", " + INCP_HOUSENUMBERADDITION + ", " + INCP_POSTALCODE + ", " + INCP_CITYNAME + ", " +
            INCP_COUNTRYOFRESIDENCE + ", " + INCP_DATEOFBIRTH + ", " + INCP_DATEOFDEATH + ", " + INCP_CITYOFBIRTH + ", " +
            INCP_COUNTRYOFBIRTH + ", " + OBJECT_CODE + ", " + INAB_ENDDATE + ", " + INAB_EFFECTIVEDATE + ", " +
            ADM_OCCUPATIONCODE + ", " + ADM_LASTNAME + ", " + ADM_FIRSTNAME + ", " + ADM_STREETNAME + ", " +
            ADM_HOUSENUMBER + ", " + ADM_HOUSENUMBERADDITION + ", " + ADM_POSTALCODE + ", " + ADM_CITYNAME + ", " +
            ADM_COUNTRYOFRESIDENCE + ", " + ADM_RESPONSIBILITY_ENDDATE + " , " + INC_ADM + " , " + FILE_ID +
            ") VALUES (" +
            // Root level property
            ":ddUuid, " +
            // IncapablePerson properties (direct + nested postalAddress)
            ":incapablePerson.gender, :incapablePerson.lastName, :incapablePerson.firstName, " +
            ":incapablePerson.postalAddress.streetName, :incapablePerson.postalAddress.houseNumber, " +
            ":incapablePerson.postalAddress.houseNumberAddition, :incapablePerson.postalAddress.postalCode, " +
            ":incapablePerson.postalAddress.cityName, :incapablePerson.postalAddress.countryOfResidence, " +
            ":incapablePerson.dateOfBirth, :incapablePerson.dateOfDeath, :incapablePerson.cityOfBirth, " +
            ":incapablePerson.countryOfBirth, " +
            // Root level properties
            ":objectCode, :inabilityEndDate, :inabilityEffectiveDate, " +
            // Administrator properties (direct + nested postalAddress)
            ":administrator.occupationCode, :administrator.lastName, :administrator.firstName, " +
            ":administrator.postalAddress.streetName, :administrator.postalAddress.houseNumber, " +
            ":administrator.postalAddress.houseNumberAddition, :administrator.postalAddress.postalCode, " +
            ":administrator.postalAddress.cityName, :administrator.postalAddress.countryOfResidence, " +
            ":administrator.responsibilityEndDate, " +
            // File tracking
            " :administratorDdUuid, :fileId" +
            ")";

    private final JdbcTemplate jdbcTemplate;

    public IncapablesDAO(JdbcTemplate jdbcTemplate) {
        this.jdbcTemplate = jdbcTemplate;
    }

    /**
     * Fetch incapable records for API processing by fileId.
     * Fetches all records from the table for the given file.
     */
    public List<IncapableDbRecord> fetchRecordsByFileId(String fileId, int limit) {
        String sql = "SELECT DD_UUID, INCP_GENDER, INCP_LASTNAME, INCP_FIRSTNAME, " +
                "INCP_STREETNAME, INCP_HOUSENUMBER, INCP_HOUSENUMBERADDITION, INCP_POSTALCODE, " +
                "INCP_CITYNAME, INCP_COUNTRYOFRESIDENCE, INCP_DATEOFBIRTH, INCP_DATEOFDEATH, " +
                "INCP_CITYOFBIRTH, INCP_COUNTRYOFBIRTH, OBJECT_CODE, INAB_ENDDATE, INAB_EFFECTIVEDATE, " +
                "ADM_OCCUPATIONCODE, ADM_LASTNAME, ADM_FIRSTNAME, ADM_STREETNAME, ADM_HOUSENUMBER, " +
                "ADM_HOUSENUMBERADDITION, ADM_POSTALCODE, ADM_CITYNAME, ADM_COUNTRYOFRESIDENCE, " +
                "ADM_RESPONSIBILITY_ENDDATE, INC_ADM, FILE_ID " +
                "FROM DD_INCAPABLES_TBL " +
                "WHERE FILE_ID = ? " +
                "AND ROWNUM <= ?";

        log.info("Data_Distributor_Incapables: Fetching records for fileId={}, limit={}", fileId, limit);
        List<IncapableDbRecord> records = jdbcTemplate.query(sql, incapableDbRecordMapper(), fileId, limit);
        log.info("Data_Distributor_Incapables: Fetched {} records for fileId={}", records.size(), fileId);
        return records;
    }


    /**
     * Row mapper for IncapableDbRecord
     */
    private RowMapper<IncapableDbRecord> incapableDbRecordMapper() {
        return (rs, rowNum) -> IncapableDbRecord.builder()
                .ddUuid(rs.getString("DD_UUID"))
                .incGender(rs.getString("INCP_GENDER"))
                .incLastName(rs.getString("INCP_LASTNAME"))
                .incFirstName(rs.getString("INCP_FIRSTNAME"))
                .incStreetName(rs.getString("INCP_STREETNAME"))
                .incHouseNumber(rs.getString("INCP_HOUSENUMBER"))
                .incHouseNumberAddition(rs.getString("INCP_HOUSENUMBERADDITION"))
                .incPostalCode(rs.getString("INCP_POSTALCODE"))
                .incCityName(rs.getString("INCP_CITYNAME"))
                .incCountryOfResidence(rs.getString("INCP_COUNTRYOFRESIDENCE"))
                .incDateOfBirth(rs.getString("INCP_DATEOFBIRTH"))
                .incDateOfDeath(rs.getString("INCP_DATEOFDEATH"))
                .incCityOfBirth(rs.getString("INCP_CITYOFBIRTH"))
                .incCountryOfBirth(rs.getString("INCP_COUNTRYOFBIRTH"))
                .objectCode(rs.getString("OBJECT_CODE"))
                .inabilityEndDate(rs.getString("INAB_ENDDATE"))
                .inabilityEffectiveDate(rs.getString("INAB_EFFECTIVEDATE"))
                .admOccupationCode(rs.getString("ADM_OCCUPATIONCODE"))
                .admLastName(rs.getString("ADM_LASTNAME"))
                .admFirstName(rs.getString("ADM_FIRSTNAME"))
                .admStreetName(rs.getString("ADM_STREETNAME"))
                .admHouseNumber(rs.getString("ADM_HOUSENUMBER"))
                .admHouseNumberAddition(rs.getString("ADM_HOUSENUMBERADDITION"))
                .admPostalCode(rs.getString("ADM_POSTALCODE"))
                .admCityName(rs.getString("ADM_CITYNAME"))
                .admCountryOfResidence(rs.getString("ADM_COUNTRYOFRESIDENCE"))
                .admResponsibilityEndDate(rs.getString("ADM_RESPONSIBILITY_ENDDATE"))
                .adminDdUuid(rs.getString("INC_ADM"))
                .fileId(rs.getString("FILE_ID"))
                .build();
    }

    /**
     * Record class to hold incapable data from DB
     */
    @lombok.Builder
    @lombok.Data
    public static class IncapableDbRecord {
        private String ddUuid;
        private String incGender;
        private String incLastName;
        private String incFirstName;
        private String incStreetName;
        private String incHouseNumber;
        private String incHouseNumberAddition;
        private String incPostalCode;
