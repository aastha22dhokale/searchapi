    private final static String MAPPING_TABLE_OPS_INSERT_SQL = "INSERT INTO DD_MAP_TBL (DD_UUID, OPS_NUMBER, TYP_OF_ENTY, CREATED_BY, CREATED_TS, FILE_ID) VALUES (?, ?, ?, 'DD_USER', SYSTIMESTAMP, ?)";
    private final static String MAPPING_TABLE_LE_INSERT_SQL = "INSERT INTO DD_MAP_TBL (DD_UUID, ORG_NUMBER, TYP_OF_ENTY, CREATED_BY, CREATED_TS, FILE_ID) VALUES (?, ?, ?, 'DD_USER', SYSTIMESTAMP, ?)";
    private final static int RS_MAPPING_TABLE_UUID_NO = 1;
    private final static int RS_MAPPING_TABLE_OPS_NUMBER_NO = 2;
    private final static int RS_MAPPING_TABLE_LE_NUMBER_NO = 2;
    private final static int RS_MAPPING_TABLE_ENTY_TYPE_NO = 3;
    private final static String MAPPING_TABLE_OPS_QUERYING_SQL_WITHOUT_PARAMETERS = "select DD_UUID, OPS_NUMBER FROM DD_MAP_TBL WHERE TYP_OF_ENTY=?";
    private final static String MAPPING_TABLE_LE_QUERYING_SQL_WITHOUT_PARAMETERS = "select DD_UUID, ORG_NUMBER FROM DD_MAP_TBL  WHERE TYP_OF_ENTY=?";
    private final static String MAPPING_TABLE_FIELD_OPS_NUMBER = "OPS_NUMBER";
    private final static String MAPPING_TABLE_FIELD_DD_UUID = "DD_UUID";
    private final static String MAPPING_TABLE_FIELD_ORG_NUMBER = "ORG_NUMBER";

    @Autowired
    private JdbcTemplate jdbcTemplate;

    public Map<String, String> fetchAllOPsUuidMappings() {

        return jdbcTemplate.query(MAPPING_TABLE_OPS_QUERYING_SQL_WITHOUT_PARAMETERS, rs -> {
            Map<String, String> result = new HashMap<>();
            while (rs.next()) {
                result.put(rs.getString(MAPPING_TABLE_FIELD_OPS_NUMBER), rs.getString(MAPPING_TABLE_FIELD_DD_UUID));
            }
            return result;
        }, FlowType.OPS.getLabel());
    }

    public Map<String, String> fetchAllLEUuidMappings() {

        return jdbcTemplate.query(MAPPING_TABLE_LE_QUERYING_SQL_WITHOUT_PARAMETERS, rs -> {
            Map<String, String> result = new HashMap<>();
            while (rs.next()) {
                result.put(rs.getString(MAPPING_TABLE_FIELD_ORG_NUMBER), rs.getString(MAPPING_TABLE_FIELD_DD_UUID));
            }
            return result;
        }, FlowType.LE.getLabel());
    }

    @Transactional
    public void batchInsertOPsMappingRecords(List<OrganisationUnitDomainWrapper> records) {
        log.info("batchInsertOPsMappingRecords: Starting batch insert for {} records", records.size());

        if (records == null || records.isEmpty()) {
            log.warn("batchInsertOPsMappingRecords: No records to insert");
            return;
        }

        try {
            int[] updateCounts = jdbcTemplate.batchUpdate(MAPPING_TABLE_OPS_INSERT_SQL, new BatchPreparedStatementSetter() {
                public void setValues(@NonNull PreparedStatement ps, int i) throws SQLException {
                    OrganisationUnitDomainWrapper record = records.get(i);
                    log.debug("Inserting OPS record {}: DD_UUID={}, OPS_NUMBER={}, FILE_ID={}",
                             i, record.getOpsUUID(), record.getOpsExternalIdentifierVal(), record.getFileId());

                    ps.setString(RS_MAPPING_TABLE_UUID_NO, record.getOpsUUID());
                    ps.setString(RS_MAPPING_TABLE_OPS_NUMBER_NO, record.getOpsExternalIdentifierVal());
                    ps.setString(RS_MAPPING_TABLE_ENTY_TYPE_NO, FlowType.OPS.getLabel());
                    ps.setString(4, record.getFileId()); // FILE_ID parameter
                }

                public int getBatchSize() {
                    return records.size();
                }
            });

            log.info("batchInsertOPsMappingRecords: Successfully inserted {} records", updateCounts.length);

        } catch (Exception e) {
            log.error("batchInsertOPsMappingRecords: Error occurred during batch insert", e);
            throw new RuntimeException("Failed to insert OPS mapping records", e);
        }
    }

    @Transactional
    public void batchInsertLEMappingRecords(List<com.ing.datadist.domain.LegalEntityParentDomain> records) {
