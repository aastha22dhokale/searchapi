package com.ing.datadist.dao;

import java.sql.ResultSet;
import java.sql.SQLException;
import java.util.List;

import com.ing.datadist.enums.FileIngestionStatus;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.jdbc.core.RowMapper;
import org.springframework.stereotype.Repository;

import com.ing.datadist.domain.FileIngestionDomain;

/**
 * FileIngestionDAO - Data access object for file ingestion tracking
 * Handles all database operations for DD_FILE_INGESTION_TBL
 */
@Repository
public class FileIngestionDAO {

    private static final Logger log = LoggerFactory.getLogger(FileIngestionDAO.class);

    private final JdbcTemplate jdbcTemplate;

    public FileIngestionDAO(JdbcTemplate jdbcTemplate) {
        this.jdbcTemplate = jdbcTemplate;
    }

    /**
     * Insert a new file ingestion record
     */
    public void insertFileIngestion(FileIngestionDomain domain) {
        String sql = "INSERT INTO DD_FILE_INGESTION_TBL (" +
                "FILE_ID, BATCH_ID, FILE_NAME, FILE_PATH, FILE_SIZE, FILE_CHECKSUM, " +
                "FLOW_NAME, FLOW_TYPE, FREQUENCY, SOURCE_SYSTEM, STATUS, RECEIVED_TS, " +
                "CREATED_BY, CREATED_TS, UPDATED_BY, UPDATED_TS) " +
                "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, SYSTIMESTAMP, ?, SYSTIMESTAMP, ?, SYSTIMESTAMP)";

        try {
            jdbcTemplate.update(sql,
                    domain.getFileId(),
                    domain.getBatchId(),
                    domain.getFileName(),
                    domain.getFilePath(),
                    domain.getFileSize(),
                    domain.getFileChecksum(),
                    domain.getFlowName(),
                    domain.getFlowType(),
                    domain.getFrequency(),
                    domain.getSourceSystem(),
                    domain.getStatus(),
                    domain.getCreatedBy(),
                    domain.getUpdatedBy());

            log.info("File Ingestion registered for FILE_ID: {}, FILE_NAME: {}",
                    domain.getFileId(), domain.getFileName());
        } catch (Exception e) {
            log.error("Error inserting file ingestion record for FILE_ID: {}",
                    domain.getFileId(), e);
            throw e;
        }
    }

    /**
     * Update file ingestion status and metrics
     */

    public void updateFileIngestionStatus(String fileId, String status,
                                          Integer totalRecords,
                                          Integer processedRecords,
                                          Integer failedRecords,
                                          String errorMessage) {

        String sql =
                "UPDATE DD_FILE_INGESTION_TBL " +
                        "SET STATUS = ?, " +
                        "    TOTAL_RECORDS = NVL(?, TOTAL_RECORDS), " +
                        "    PROCESSED_RECORDS = NVL(?, PROCESSED_RECORDS), " +
                        "    FAILED_RECORDS = NVL(?, FAILED_RECORDS), " +
                        "    ERROR_MESSAGE = ?, " +
                        "    UPDATED_BY = 'DD_SYSTEM', UPDATED_TS = SYSTIMESTAMP " +
                        "WHERE FILE_ID = ?";

        jdbcTemplate.update(sql,
                status,
                totalRecords,
                processedRecords,
                failedRecords,
                errorMessage,
                fileId);
    }    /**
     * Update file processing end timestamp and final metrics
     */
    public void updateFileProcessingEnd(String fileId, Long fileSize, String fileChecksum,
                                        Long totalRecords, Long processedRecords, Long failedRecords) {

        String status = (failedRecords != null && failedRecords > 0)
                ? FileIngestionStatus.PARTIALLY_COMPLETED.getValue()
                : FileIngestionStatus.COMPLETED.getValue();

        String sql = "UPDATE DD_FILE_INGESTION_TBL " +
                "SET PROCESSING_END_TS = SYSTIMESTAMP, " +
                "    FILE_SIZE = NVL(?, FILE_SIZE), " +
                "    TOTAL_RECORDS = NVL(?, TOTAL_RECORDS), " +
                "    PROCESSED_RECORDS = NVL(?, PROCESSED_RECORDS), " +
                "    FAILED_RECORDS = NVL(?, FAILED_RECORDS), " +
                "    STATUS = ?, " +
                "    UPDATED_BY = 'DD_SYSTEM', UPDATED_TS = SYSTIMESTAMP " +
                "WHERE FILE_ID = ?";

        jdbcTemplate.update(sql,
                fileSize,
                totalRecords != null ? totalRecords.intValue() : null,
                processedRecords != null ? processedRecords.intValue() : null,
                failedRecords != null ? failedRecords.intValue() : null,
                status,
                fileId);
    }
    /**
     * Update file processing metrics during processing
     */
    public void updateFileMetrics(String fileId, Long processedRecords, Long failedRecords, Long skippedRecords) {
        String sql = "UPDATE DD_FILE_INGESTION_TBL " +
                "SET PROCESSED_RECORDS = NVL(?, PROCESSED_RECORDS), " +
                "    FAILED_RECORDS = NVL(?, FAILED_RECORDS), " +
                "    SKIPPED_RECORDS = NVL(?, SKIPPED_RECORDS), " +
                "    UPDATED_BY = 'DD_SYSTEM', UPDATED_TS = SYSTIMESTAMP " +
                "WHERE FILE_ID = ?";

        jdbcTemplate.update(sql,
                processedRecords != null ? processedRecords.intValue() : null,
                failedRecords != null ? failedRecords.intValue() : null,
                skippedRecords != null ? skippedRecords.intValue() : null,
                fileId);
    }
    /**
     * Mark file processing as started
     */
    public void updateProcessingStart(String fileId, String batchId) {
        String sql = "UPDATE DD_FILE_INGESTION_TBL " +
                "SET STATUS = 'IN_PROGRESS', PROCESSING_START_TS = SYSTIMESTAMP, " +
                "BATCH_ID = ?, UPDATED_BY = 'DD_SYSTEM', UPDATED_TS = SYSTIMESTAMP " +
                "WHERE FILE_ID = ?";

        try {
            jdbcTemplate.update(sql, batchId, fileId);
            log.info("File Ingestion processing started for FILE_ID: {}", fileId);
        } catch (Exception e) {
            log.error("Error updating processing start for FILE_ID: {}", fileId, e);
            throw e;
        }
    }

    /**
     * Retrieve file ingestion record by file ID
     */
    public FileIngestionDomain getFileIngestionByFileId(String fileId) {
        String sql = "SELECT * FROM DD_FILE_INGESTION_TBL WHERE FILE_ID = ?";

        try {
            List<FileIngestionDomain> results = jdbcTemplate.query(sql,
                    new FileIngestionRowMapper(), fileId);

            if (results.isEmpty()) {
                log.warn("No file ingestion record found for FILE_ID: {}", fileId);
                return null;
            }
            return results.getFirst();
        } catch (Exception e) {
            log.error("Error retrieving file ingestion for FILE_ID: {}", fileId, e);
            throw e;
        }
    }

    /**
     * Get files by status
     */
    public List<FileIngestionDomain> getFilesByStatus(String status) {
        String sql = "SELECT * FROM DD_FILE_INGESTION_TBL WHERE STATUS = ? ORDER BY RECEIVED_TS ASC";

        try {
            return jdbcTemplate.query(sql, new FileIngestionRowMapper(), status);
        } catch (Exception e) {
            log.error("Error retrieving files by status: {}", status, e);
            throw e;
        }
    }

    /**
     * Row mapper for FileIngestionDomain
     */
    private static class FileIngestionRowMapper implements RowMapper<FileIngestionDomain> {
        @Override
        public FileIngestionDomain mapRow(ResultSet rs, int rowNum) throws SQLException {
            FileIngestionDomain domain = new FileIngestionDomain();
            domain.setFileId(rs.getString("FILE_ID"));
            domain.setBatchId(rs.getString("BATCH_ID"));
            domain.setFileName(rs.getString("FILE_NAME"));
            domain.setFilePath(rs.getString("FILE_PATH"));
            domain.setFileSize(rs.getLong("FILE_SIZE"));
            domain.setFileChecksum(rs.getString("FILE_CHECKSUM"));
            domain.setFlowName(rs.getString("FLOW_NAME"));
            domain.setFlowType(rs.getString("FLOW_TYPE"));
            domain.setFrequency(rs.getString("FREQUENCY"));
            domain.setSourceSystem(rs.getString("SOURCE_SYSTEM"));
            domain.setStatus(rs.getString("STATUS"));

            // Convert sql.Timestamp to LocalDateTime
            java.sql.Timestamp receivedTs = rs.getTimestamp("RECEIVED_TS");
            if (receivedTs != null) {
                domain.setReceivedTs(receivedTs.toLocalDateTime());
            }

            java.sql.Timestamp processingStartTs = rs.getTimestamp("PROCESSING_START_TS");
            if (processingStartTs != null) {
                domain.setProcessingStartTs(processingStartTs.toLocalDateTime());
            }

            java.sql.Timestamp processingEndTs = rs.getTimestamp("PROCESSING_END_TS");
            if (processingEndTs != null) {
                domain.setProcessingEndTs(processingEndTs.toLocalDateTime());
            }

            // Convert Integer to Long for record counts
            Integer totalRecords = rs.getObject("TOTAL_RECORDS", Integer.class);
            if (totalRecords != null) {
                domain.setTotalRecords(totalRecords.longValue());
            }

            Integer processedRecords = rs.getObject("PROCESSED_RECORDS", Integer.class);
            if (processedRecords != null) {
                domain.setProcessedRecords(processedRecords.longValue());
            }

            Integer failedRecords = rs.getObject("FAILED_RECORDS", Integer.class);
            if (failedRecords != null) {
                domain.setFailedRecords(failedRecords.longValue());
            }

            Integer skippedRecords = rs.getObject("SKIPPED_RECORDS", Integer.class);
            if (skippedRecords != null) {
                domain.setSkippedRecords(skippedRecords.longValue());
            }

            domain.setErrorMessage(rs.getString("ERROR_MESSAGE"));
            domain.setRetryCount(rs.getObject("RETRY_COUNT", Integer.class));
            domain.setCreatedBy(rs.getString("CREATED_BY"));

            java.sql.Timestamp createdTs = rs.getTimestamp("CREATED_TS");
            if (createdTs != null) {
                domain.setCreatedTs(createdTs.toLocalDateTime());
            }

            domain.setUpdatedBy(rs.getString("UPDATED_BY"));

            java.sql.Timestamp updatedTs = rs.getTimestamp("UPDATED_TS");
            if (updatedTs != null) {
                domain.setUpdatedTs(updatedTs.toLocalDateTime());
            }

            return domain;
        }
    }

    public void updateTotalNumberOfRecords(String fileId, Long totalRecords, Long fileSize) {
        String sql = "UPDATE DD_FILE_INGESTION_TBL " +
                "SET TOTAL_RECORDS = ?,FILE_SIZE = ? " +
                "WHERE FILE_ID = ?";

        try {
            jdbcTemplate.update(sql, totalRecords, fileSize, fileId);
            log.info("File Ingestion totalRecords updated for FILE_ID: {}, totalRecords: {}, fileSize:{}", fileId, totalRecords, fileSize);
        } catch (Exception e) {
            log.error("Error updating file ingestion totalRecords for FILE_ID: {}", fileId, e);
            throw e;
        }
    }
}
